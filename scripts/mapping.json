{
  "$comment": "Mapping ERP LedsC4 → Shopify. Fuente de verdad del importador. Las columnas se leen por POSICIÓN (column_index), no por nombre, porque los nombres varían por idioma y pueden cambiar en el tiempo. Los nombres en column_name_es son sólo orientativos.",
  "version": "1.0.0",
  "updated": "2026-05-05",
  "files": {
    "surtido": {
      "path_pattern": "/productos/listado_productos_{LOCALE}.csv",
      "locales": [
        "ES",
        "EN",
        "IT",
        "DE",
        "FR",
        "PT"
      ],
      "primary_locale": "ES",
      "encoding": "utf-8",
      "delimiter": ",",
      "frequency": "weekly",
      "key_column_index": 0,
      "duplicate_policy": "first_wins_log_warning"
    },
    "stock": {
      "path": "/stock/stock.csv",
      "encoding": "utf-8",
      "delimiter": ",",
      "frequency": "every_6h",
      "schema": [
        "sku",
        "inventario"
      ]
    },
    "precios": {
      "path": "/precios/precios_productos.csv",
      "encoding": "utf-8",
      "delimiter": ",",
      "frequency": "every_6h",
      "schema": [
        "sku",
        "tarifa"
      ],
      "currency": "EUR"
    }
  },
  "publication_rules": {
    "$comment": "Un producto sólo se publica al catalog 'Outlet general' si cumple las 3 condiciones. Sustituye al criterio antiguo basado en tag 'Coleccion:2026'.",
    "must_be_in_surtido": true,
    "must_have_stock_gt_zero": true,
    "must_have_price_gt_zero": true,
    "on_failure": "unpublish_from_catalog"
  },
  "columns": {
