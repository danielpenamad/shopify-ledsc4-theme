{% comment %}
  Header simplificado SOLO para customer aprobado en el template 'index'
  (la home rediseñada como dashboard B2B). Logo a la izquierda, "Mi cuenta"
  + "Cerrar sesión" a la derecha. Sin nav comercial — la nav vive en
  header-group de Dawn cuando entran a /collections/*.

  Se renderiza desde layout/theme.liquid antes del <main> y no se carga en
  ninguna otra ruta. Se usa como snippet (no section) para evitar entrar
  en el editor de tema y simplificar el switch.
{% endcomment %}

<header class="b2b-header-aprobado" role="banner">
  <div class="b2b-header-aprobado__inner">
    <a href="/" class="b2b-header-aprobado__brand" aria-label="LedsC4 Outlet — Inicio">
      <img
        src="{{ 'logo-ledsc4.svg' | asset_url }}"
        alt="LedsC4"
        width="140"
        height="auto"
        loading="eager"
      >
    </a>

    <nav class="b2b-header-aprobado__nav" aria-label="Cuenta">
      <a href="/account" class="b2b-header-aprobado__link">Mi cuenta</a>
      <a href="/account/logout" class="b2b-header-aprobado__link b2b-header-aprobado__link--ghost">
        Cerrar sesión
      </a>
    </nav>
  </div>
</header>

{% style %}
  .b2b-header-aprobado {
    background: rgb(var(--color-background));
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    padding: 0.875rem 1.5rem;
    font-family: var(--font-ledsc4-ui);
  }
  .b2b-header-aprobado__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .b2b-header-aprobado__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .b2b-header-aprobado__brand img {
    display: block;
    max-width: 140px;
    height: auto;
  }
  .b2b-header-aprobado__nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .b2b-header-aprobado__link {
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    padding: 0.5rem 0.875rem;
    border-radius: 0.375rem;
    transition: background-color 0.15s ease;
  }
  .b2b-header-aprobado__link:hover {
    background: rgba(var(--color-foreground), 0.06);
  }
  .b2b-header-aprobado__link--ghost {
    color: rgba(var(--color-foreground), 0.65);
  }
  @media (max-width: 480px) {
    .b2b-header-aprobado {
      padding: 0.75rem 1rem;
    }
    .b2b-header-aprobado__brand img {
      max-width: 110px;
    }
    .b2b-header-aprobado__link {
      padding: 0.4rem 0.6rem;
      font-size: 0.8125rem;
    }
  }
{% endstyle %}
