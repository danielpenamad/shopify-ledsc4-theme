{% comment %}
  LedsC4 specifications table — full product specs from metafields.
{% endcomment %}

{%- assign ns = product.metafields.product -%}

{%- capture specs_rows -%}
  {%- if ns.familia.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.familia' | t }}</td><td>{{ ns.familia.value }}</td></tr>{%- endif -%}
  {%- if ns.catalogo.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.catalogo' | t }}</td><td>{{ ns.catalogo.value }}</td></tr>{%- endif -%}
  {%- if ns.garantia.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.garantia' | t }}</td><td>{{ 'ledsc4.product.specs.garantia_value' | t: value: ns.garantia.value }}</td></tr>{%- endif -%}
  {%- if ns.material.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.material' | t }}</td><td>{{ ns.material.value }}</td></tr>{%- endif -%}
  {%- if ns.acabado.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.acabado' | t }}</td><td>{{ ns.acabado.value }}</td></tr>{%- endif -%}
  {%- if ns.etiqueta_vf.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.voltaje' | t }}</td><td>{{ ns.etiqueta_vf.value }}</td></tr>{%- endif -%}
  {%- if ns.dim_ancho_mm.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.ancho' | t }}</td><td>{{ ns.dim_ancho_mm.value }}</td></tr>{%- endif -%}
  {%- if ns.dim_alto_mm.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.alto' | t }}</td><td>{{ ns.dim_alto_mm.value }}</td></tr>{%- endif -%}
  {%- if ns.dim_largo_mm.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.largo' | t }}</td><td>{{ ns.dim_largo_mm.value }}</td></tr>{%- endif -%}
  {%- if ns.proyeccion_mm.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.proyeccion' | t }}</td><td>{{ ns.proyeccion_mm.value }}</td></tr>{%- endif -%}
  {%- if ns.fuente_luz.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.fuente_luz' | t }}</td><td>{{ ns.fuente_luz.value }}</td></tr>{%- endif -%}
  {%- if ns.incluye_bombilla.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.incluye_bombilla' | t }}</td><td>{{ ns.incluye_bombilla.value }}</td></tr>{%- endif -%}
  {%- if ns.eficiencia_energetica.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.eficiencia_energetica' | t }}</td><td>{{ ns.eficiencia_energetica.value }}</td></tr>{%- endif -%}
  {%- if ns.peso_neto_kg.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.peso_neto' | t }}</td><td>{{ ns.peso_neto_kg.value }}</td></tr>{%- endif -%}
  {%- if ns.vatios.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.potencia' | t }}</td><td>{{ ns.vatios.value }}</td></tr>{%- endif -%}
  {%- if ns.lumenes.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.lumenes' | t }}</td><td>{{ ns.lumenes.value }}</td></tr>{%- endif -%}
  {%- if ns.lumenes_reales.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.lumenes_reales' | t }}</td><td>{{ ns.lumenes_reales.value }}</td></tr>{%- endif -%}
  {%- if ns.temperatura_color.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.temperatura_color' | t }}</td><td>{{ ns.temperatura_color.value }}</td></tr>{%- endif -%}
  {%- if ns.cri.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.cri' | t }}</td><td>{{ ns.cri.value }}</td></tr>{%- endif -%}
  {%- if ns.rayo_luz.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.angulo_haz' | t }}</td><td>{{ ns.rayo_luz.value }}</td></tr>{%- endif -%}
  {%- if ns.tipo_regulacion.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.regulacion' | t }}</td><td>{{ ns.tipo_regulacion.value }}</td></tr>{%- endif -%}
  {%- if ns.ip.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.ip' | t }}</td><td>{{ ns.ip.value }}</td></tr>{%- endif -%}
  {%- if ns.ik.value != blank -%}<tr><td>{{ 'ledsc4.product.specs.ik' | t }}</td><td>{{ ns.ik.value }}</td></tr>{%- endif -%}
{%- endcapture -%}

{%- if specs_rows != blank -%}
<div class="specs-table-wrapper">
  <table class="specs-table">
    <tbody>
      {{ specs_rows }}
    </tbody>
  </table>
</div>
{%- endif -%}
