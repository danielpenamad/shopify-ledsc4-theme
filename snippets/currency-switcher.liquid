{%- comment -%}
  Currency switcher — divisa de DISPLAY (cosmética) para LedsC4 B2B.

  Cambio respecto a versiones previas (PR #140, #141):
  Ya NO postea a /localization. El B2B logueado está clavado al Market ES
  (única divisa real: EUR) por las reglas de B2B Locations, así que un
  POST a /localization se revierte o redirige cross-domain y rompe sesión.

  Modo actual: cosmético puro.
    - El switcher SOLO setea la cookie `ledsc4_currency` (EUR|USD|GBP, 30
      días) y dispara `ledsc4:currency-changed`.
    - El asset `ledsc4-currency-display.js` escucha ese evento y reescribe
      los nodos `[data-eur-amount]` aplicando la tasa de
      `window.LEDSC4_FX` (poblada desde el shop metafield
      ledsc4.fx_rates, refrescado semanalmente por la EF update-fx-rates).
    - EUR es la divisa real del carrito, del draft order y de la factura.
      Lo que muestra USD/GBP es "≈" sobre el importe EUR.

  Render: llamado desde b2b-header.liquid y b2b-header-simple.liquid. Sin
  auto-detect por IP — default EUR.
{%- endcomment -%}

<div class="ledsc4-currency-switcher" data-ledsc4-currency-switcher>
  <button
    type="button"
    class="ledsc4-currency-switcher__toggle"
    aria-expanded="false"
    aria-controls="ledsc4-currency-panel"
    aria-label="{{ 'ledsc4.common.currency.switcher_label' | t }}"
    data-ledsc4-currency-toggle
  >
    <span aria-hidden="true" data-ledsc4-currency-symbol>€</span>
    <span data-ledsc4-currency-code>EUR</span>
    <span class="ledsc4-currency-switcher__caret" aria-hidden="true">▾</span>
  </button>

  <ul
    id="ledsc4-currency-panel"
    class="ledsc4-currency-switcher__panel"
    role="list"
    data-ledsc4-currency-panel
  >
    <li>
      <button
        type="button"
        class="ledsc4-currency-switcher__option"
        data-ledsc4-currency="EUR"
      >
        <span aria-hidden="true">€</span> EUR
      </button>
    </li>
    <li>
      <button
        type="button"
        class="ledsc4-currency-switcher__option"
        data-ledsc4-currency="USD"
      >
        <span aria-hidden="true">$</span> USD
      </button>
    </li>
    <li>
      <button
        type="button"
        class="ledsc4-currency-switcher__option"
        data-ledsc4-currency="GBP"
      >
        <span aria-hidden="true">£</span> GBP
      </button>
    </li>
  </ul>
</div>

<style>
  .ledsc4-currency-switcher {
    position: relative;
    font-family: inherit;
  }
  .ledsc4-currency-switcher__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: inherit;
    font-size: 1.5rem;
    font-weight: 500;
    color: rgb(var(--color-foreground, 15 18 23));
    background: transparent;
    border: 1px solid rgba(15, 18, 23, 0.15);
    border-radius: 4px;
    padding: 0.6rem 1rem;
    cursor: pointer;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    white-space: nowrap;
  }
  .ledsc4-currency-switcher__toggle:hover {
    border-color: rgba(15, 18, 23, 0.3);
    background: rgba(15, 18, 23, 0.04);
  }
  .ledsc4-currency-switcher__caret {
    font-size: 0.7em;
    line-height: 1;
    transition: transform 0.15s ease;
  }
  .ledsc4-currency-switcher__toggle[aria-expanded="true"] .ledsc4-currency-switcher__caret {
    transform: rotate(180deg);
  }
  .ledsc4-currency-switcher__panel {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    display: none;
    position: absolute;
    top: calc(100% + 0.25rem);
    right: 0;
    min-width: 140px;
    background: #ffffff;
    border: 1px solid rgba(15, 18, 23, 0.08);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(15, 18, 23, 0.10);
    z-index: 60;
  }
  .ledsc4-currency-switcher__panel.ledsc4-currency-switcher__panel--open {
    display: block;
  }
  .ledsc4-currency-switcher__option {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.5rem 1rem;
    text-decoration: none;
    color: rgb(var(--color-foreground, 15 18 23));
    font-family: inherit;
    font-size: 1.6rem;
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }
  .ledsc4-currency-switcher__option:hover {
    background: rgba(15, 18, 23, 0.06);
  }
  .ledsc4-currency-switcher__option--active {
    color: var(--color-ledsc4-accent, #1a1f27);
    font-weight: 600;
  }
</style>

<script>
  (function () {
    var COOKIE_NAME = 'ledsc4_currency';
    var COOKIE_MAX_AGE = 60 * 60 * 24 * 30; // 30 días
    var SUPPORTED = { EUR: 1, USD: 1, GBP: 1 };
    var SYMBOLS = { EUR: '€', USD: '$', GBP: '£' };

    function getCookie() {
      var m = document.cookie.match(/(?:^|; )ledsc4_currency=([^;]*)/);
      var v = m ? decodeURIComponent(m[1]) : null;
      return v && SUPPORTED[v] ? v : 'EUR';
    }
    function setCookie(value) {
      var secure = location.protocol === 'https:' ? '; Secure' : '';
      document.cookie =
        COOKIE_NAME + '=' + encodeURIComponent(value) +
        '; Path=/; Max-Age=' + COOKIE_MAX_AGE +
        '; SameSite=Lax' + secure;
    }

    var switcher = document.querySelector('[data-ledsc4-currency-switcher]');
    if (!switcher) return;
    var toggle = switcher.querySelector('[data-ledsc4-currency-toggle]');
    var panel = switcher.querySelector('[data-ledsc4-currency-panel]');
    var labelSymbol = switcher.querySelector('[data-ledsc4-currency-symbol]');
    var labelCode = switcher.querySelector('[data-ledsc4-currency-code]');

    function syncLabel(cur) {
      if (labelSymbol) labelSymbol.textContent = SYMBOLS[cur] || '€';
      if (labelCode) labelCode.textContent = cur;
      switcher.querySelectorAll('[data-ledsc4-currency]').forEach(function (btn) {
        var active = btn.getAttribute('data-ledsc4-currency') === cur;
        btn.classList.toggle('ledsc4-currency-switcher__option--active', active);
        if (active) {
          btn.setAttribute('aria-current', 'true');
        } else {
          btn.removeAttribute('aria-current');
        }
      });
    }

    // Pinta label inicial desde la cookie (no desde Liquid: cart.currency
    // en B2B ES siempre será EUR aunque el usuario haya elegido USD/GBP).
    var initial = getCookie();
    if (!document.cookie.match(/(?:^|; )ledsc4_currency=/)) {
      setCookie(initial);
    }
    syncLabel(initial);

    // Click en opción → cookie + evento. Sin form submit.
    switcher.querySelectorAll('[data-ledsc4-currency]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        var cur = btn.getAttribute('data-ledsc4-currency');
        if (!cur || !SUPPORTED[cur]) return;
        setCookie(cur);
        syncLabel(cur);
        closePanel();
        window.dispatchEvent(new CustomEvent('ledsc4:currency-changed', { detail: { currency: cur } }));
      });
    });

    function closePanel() {
      if (!toggle || !panel) return;
      toggle.setAttribute('aria-expanded', 'false');
      panel.classList.remove('ledsc4-currency-switcher__panel--open');
    }
    if (toggle && panel) {
      toggle.addEventListener('click', function (e) {
        e.stopPropagation();
        var expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        panel.classList.toggle('ledsc4-currency-switcher__panel--open', !expanded);
      });
      document.addEventListener('click', function (e) {
        if (switcher.contains(e.target)) return;
        closePanel();
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closePanel();
      });
    }
  })();
</script>
