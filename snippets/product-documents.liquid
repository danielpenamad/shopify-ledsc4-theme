{% comment %}
  LedsC4 product documents — links to PDFs and technical files.
{% endcomment %}

{%- assign ns = product.metafields.product -%}

{%- capture doc_links -%}
  {%- if ns.ficha_url.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.ficha_url.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        Ficha técnica
      </a>
    </li>
  {%- endif -%}
  {%- if ns.fotometria_url.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.fotometria_url.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Fotometría
      </a>
    </li>
  {%- endif -%}
  {%- if ns.ee_url.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.ee_url.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Etiqueta energética
      </a>
    </li>
  {%- endif -%}
  {%- if ns.ficha_comercial_url.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.ficha_comercial_url.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Plano comercial
      </a>
    </li>
  {%- endif -%}
  {%- if ns.accesorio_url.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.accesorio_url.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Información técnica accesorios
      </a>
    </li>
  {%- endif -%}
  {%- if ns.ies_url.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.ies_url.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Archivo IES
      </a>
    </li>
  {%- endif -%}
  {%- if ns.ldt_url.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.ldt_url.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Archivo LDT
      </a>
    </li>
  {%- endif -%}
  {%- if ns.modelo_3d_url.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.modelo_3d_url.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        Modelo 3D
      </a>
    </li>
  {%- endif -%}
  {%- comment -%}
    Bloque "Instrucciones de montaje" intencionalmente desactivado.
    El masterfile CSV no aporta una columna PDF para IMC; la columna IMC del
    feed (col 64) es solo el código del producto, mapeado a product.imc como
    texto. Si en el futuro entra un feed de PDFs de instrucciones de montaje,
    crear la definition correspondiente, ajustar la key del ns.* y quitar el
    wrapper de comentario que envuelve al bloque siguiente para reactivarlo.
  {%- endcomment -%}
  {%- comment -%}
  {%- if ns.pdf_imc.value != blank -%}
    <li class="doc-link">
      <a href="{{ ns.pdf_imc.value }}" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Instrucciones de montaje
      </a>
    </li>
  {%- endif -%}
  {%- endcomment -%}
{%- endcapture -%}

{%- if doc_links != blank -%}
<ul class="doc-links-list">
  {{ doc_links }}
</ul>
{%- endif -%}
