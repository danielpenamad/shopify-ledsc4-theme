# Secrets necesarios en Supabase Project Settings → Edge Functions → Secrets.
# NO se commitea el .env real — estos nombres son los que hay que setear
# manualmente en cada proyecto (tu sandbox y, más adelante, el del cliente).

SHOPIFY_STORE_DOMAIN=ledsc4-b2b-outlet.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx_pon_el_token_real
SHOPIFY_API_VERSION=2025-10

# Para create-company-for-customer — secret compartido con Shopify Flow (el
# step Send HTTP request pasa este valor en el header X-Webhook-Secret).
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREATE_COMPANY_WEBHOOK_SECRET=<hex_32_bytes>

