SHOPIFY_STORE_DOMAIN=ledsc4-b2b-outlet.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-10

# Currency-A — Open Exchange Rates.
# El código asume plan FREE: base USD obligatoria, ~1000 calls/mes
# (el cron diario usa ~30). El edge function pide symbols=EUR,USD,GBP
# y recalcula a EUR-base internamente. Si en el futuro se contrata
# plan paid, se puede simplificar usando base=EUR directamente.
# Generar app_id en https://openexchangerates.org/account/app-ids
# Configurar en Supabase como secret de la edge function
# update-currency-rates además de aquí (script one-shot
# scripts/activate-market-currencies.mjs lo lee de env local).
OPEN_EXCHANGE_RATES_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
