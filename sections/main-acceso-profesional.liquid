      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Acceso profesional"
    }
  ]
}
