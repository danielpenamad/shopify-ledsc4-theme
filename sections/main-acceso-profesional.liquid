  {%- comment -%}
    Form de registro B2B real.

    Sustituye al /account/register clásico (que Shopify rompió al forzar new
    customer accounts: redirige a OAuth y pierde campos custom). Ver
    docs/pagina-acceso-profesional.md y supabase/README.md
    (función register-b2b-customer).

    Al enviar, fetch a la edge function `register-b2b-customer` (URL en
    settings.register_b2b_endpoint). Auth: HMAC-SHA256 de
    `<timestamp>:<nonce>` firmado por Liquid SSR con el metafield de shop
    `b2b.hmac_secret` (access.storefront = NONE: legible en Liquid, NO
    expuesto a Storefront API ni HTML). TTL 5 min.

    Si el metafield no está seteado, el HMAC se computa contra cadena
    vacía y el server lo rechaza — comportamiento correcto durante setup.
    Setear el metafield de shop b2b.hmac_secret con valor idéntico al
    Supabase secret REGISTER_B2B_HMAC_SECRET.
  {%- endcomment -%}
  {%- assign register_now_ts = 'now' | date: '%s' -%}
  {%- assign register_nonce_seed = register_now_ts | append: ':' | append: section.id | append: ':' | append: shop.id -%}
  {%- assign register_nonce = register_nonce_seed | sha256 | slice: 0, 24 -%}
  {%- assign register_hmac_payload = register_now_ts | append: ':' | append: register_nonce -%}
  {%- assign register_hmac_sig = register_hmac_payload | hmac_sha256: shop.metafields.b2b.hmac_secret.value -%}

  <section id="registro" class="b2b-acceso__form-block" aria-labelledby="b2b-acceso-form-heading">
    <h2 id="b2b-acceso-form-heading" class="b2b-acceso__h2">{{ 'ledsc4.acceso.form.heading' | t }}</h2>
    <ol class="b2b-acceso__form-steps">
      <li>{{ 'ledsc4.acceso.form.step1_html' | t }}</li>
      <li>{{ 'ledsc4.acceso.form.step2_html' | t }}</li>
      <li>{{ 'ledsc4.acceso.form.step3_html' | t }}</li>
    </ol>

    <form
      id="b2b-registro-form"
      class="b2b-acceso__form"
      data-endpoint="{{ settings.register_b2b_endpoint }}"
      novalidate
      onsubmit="return false;"
    >
      <input type="hidden" name="timestamp" value="{{ register_now_ts }}">
      <input type="hidden" name="nonce" value="{{ register_nonce }}">
      <input type="hidden" name="signature" value="{{ register_hmac_sig }}">

      <div id="b2b-registro-banner" class="b2b-acceso__form-banner" hidden role="alert"></div>

      <fieldset class="b2b-acceso__fieldset">
        <legend class="b2b-acceso__fieldset-legend">{{ 'ledsc4.acceso.form.legend_personales' | t }}</legend>
        <div class="b2b-acceso__form-grid">
          <div class="b2b-acceso__field">
            <label for="reg-nombre">{{ 'ledsc4.acceso.form.label_nombre' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            <input type="text" name="nombre" id="reg-nombre" autocomplete="given-name" required maxlength="100">
            <span class="b2b-acceso__field-error" data-field="nombre" hidden></span>
          </div>
          <div class="b2b-acceso__field">
            <label for="reg-apellidos">{{ 'ledsc4.acceso.form.label_apellidos' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            <input type="text" name="apellidos" id="reg-apellidos" autocomplete="family-name" required maxlength="100">
            <span class="b2b-acceso__field-error" data-field="apellidos" hidden></span>
          </div>
          <div class="b2b-acceso__field">
            <label for="reg-email">{{ 'ledsc4.acceso.form.label_email' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            <input type="email" name="email" id="reg-email" autocomplete="email" required maxlength="254" inputmode="email">
            <span class="b2b-acceso__field-error" data-field="email" hidden></span>
          </div>
          <div class="b2b-acceso__field">
            <label for="reg-telefono">{{ 'ledsc4.acceso.form.label_telefono' | t }}</label>
            <input type="tel" name="telefono" id="reg-telefono" autocomplete="tel" maxlength="30" inputmode="tel">
            <span class="b2b-acceso__field-error" data-field="telefono" hidden></span>
          </div>
        </div>
      </fieldset>

      <fieldset class="b2b-acceso__fieldset">
        <legend class="b2b-acceso__fieldset-legend">{{ 'ledsc4.acceso.form.legend_empresa' | t }}</legend>
        <div class="b2b-acceso__form-grid">
          <div class="b2b-acceso__field b2b-acceso__field--wide">
            <label for="reg-empresa">{{ 'ledsc4.acceso.form.label_razon_social' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            <input type="text" name="empresa" id="reg-empresa" autocomplete="organization" required maxlength="200">
            <span class="b2b-acceso__field-error" data-field="empresa" hidden></span>
          </div>
          <div class="b2b-acceso__field">
            <label for="reg-nif">{{ 'ledsc4.acceso.form.label_nif' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            <input type="text" name="nif" id="reg-nif" required maxlength="20" autocapitalize="characters" spellcheck="false">
            <span class="b2b-acceso__field-error" data-field="nif" hidden></span>
          </div>
          {%- comment -%}
            Sector eliminado del UI (PR A, mayo 2026). Mantenemos un hidden
            con valor "otro" para que la edge function `register-b2b-customer`
            (que valida sector ∈ SECTOR_ENUM y popula el metafield b2b.sector)
            siga funcionando sin cambios server-side. El metafield queda
            poblado con "otro" hasta que el equipo decida si lo retira del
            esquema o lo deja como histórico.
          {%- endcomment -%}
          <input type="hidden" name="sector" value="otro">
          <div class="b2b-acceso__field">
            <label for="reg-pais">{{ 'ledsc4.acceso.form.label_pais' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            {%- comment -%}
              Lista de 89 países (Europa + América + N. África + Oriente Medio),
              orden: España primero, resto alfabético por nombre en español.
              Label "UK" literal para GB en todos los locales. Backend
              normalizeCountry acepta cualquier ISO-2 sin allowlist.
            {%- endcomment -%}
