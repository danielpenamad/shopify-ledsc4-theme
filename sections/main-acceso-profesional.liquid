      "content": "Apariencia"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Esquema de color",
      "options": [
        { "value": "dark", "label": "Oscuro (coherente con home anónima)" },
        { "value": "light", "label": "Claro (mayor legibilidad de texto largo)" }
      ],
      "default": "dark"
    },
    {
      "type": "checkbox",
      "id": "show_logo_header",
      "label": "Mostrar logo en cabecera",
