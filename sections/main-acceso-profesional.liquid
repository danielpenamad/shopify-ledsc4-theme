      <a href="{{ locale_prefix }}/pages/politica-de-privacidad">{{ 'ledsc4.common.footer.privacidad' | t }}</a>
      <span aria-hidden="true">·</span>
      <a href="{{ locale_prefix }}/pages/condiciones-de-uso">{{ 'ledsc4.common.footer.condiciones' | t }}</a>
      <span aria-hidden="true">·</span>
