      {%- assign current_year = 'now' | date: '%Y' -%}
      {{ 'ledsc4.common.footer.copyright_html' | t: year: current_year }}
    </p>
  </footer>
</section>

<style>
  .b2b-acceso {
    /* Paleta ledsc4.com — blanco + negro, acento azul corporativo
       `var(--color-ledsc4-accent)`. Esquema único (sin dark/light alternativos). */
    --bg: #ffffff;
    --bg-alt: #f5f5f7;
    --bg-card: rgba(0, 0, 0, 0.04);
    --fg: #000000;
    --fg-strong: #000000;
    --fg-muted: rgba(0, 0, 0, 0.72);
    --fg-dim: rgba(0, 0, 0, 0.50);
    --accent: var(--color-ledsc4-accent);
    --border: rgba(0, 0, 0, 0.10);

    background: var(--bg);
    color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    line-height: 1.6;
    padding: var(--b2b-acceso-pad-top, 64px) 1.5rem var(--b2b-acceso-pad-bottom, 80px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .b2b-acceso *,
  .b2b-acceso *::before,
  .b2b-acceso *::after {
    box-sizing: border-box;
  }

  /* Tema Dawn convención: html { font-size: 62.5% } → 1rem = 10px.
     Toda la sección usa rem en escala Dawn (1.7rem = 17px, 4rem = 40px,
     etc.) para que el cuerpo y los headings rendericen al tamaño real
     que el copy de lectura larga necesita. Si en el futuro se cambia
     `--font-body-scale` desde theme settings, los rem escalan
     proporcionalmente — comportamiento correcto. */

  .b2b-acceso > * {
    width: 100%;
    max-width: 780px;
  }

  /* HERO */
  .b2b-acceso__brand {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .b2b-acceso__brand img {
    max-width: 100%;
    height: auto;
    display: inline-block;
  }
  .b2b-acceso__brand-wordmark {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.4rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg);
  }
  .b2b-acceso__brand-wordmark em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.85em;
  }

  .b2b-acceso__hero {
    text-align: center;
    margin-bottom: 4rem;
  }

  .b2b-acceso__eyebrow {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.25rem;
  }

  .b2b-acceso__heading {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.6rem, 6vw, 6.4rem);
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 1.5rem;
    color: var(--fg-strong);
    letter-spacing: -0.015em;
  }
  .b2b-acceso__heading em {
    font-style: italic;
    color: var(--accent);
    font-weight: 400;
    display: block;
  }
  @media (min-width: 750px) {
    .b2b-acceso__heading em {
      display: inline;
    }
  }

  .b2b-acceso__lead {
    font-size: clamp(1.7rem, 1.8vw, 2.1rem);
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0 auto;
    max-width: 60ch;
  }

  /* Bloques de contenido */
  .b2b-acceso__block {
    margin: 0 0 3.5rem;
  }

  .b2b-acceso__h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 3vw, 3.2rem);
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 1.25rem;
    color: var(--fg-strong);
    letter-spacing: -0.01em;
  }

  .b2b-acceso__h3 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.3;
    margin: 0 0 0.625rem;
    color: var(--fg-strong);
    letter-spacing: -0.005em;
  }

  .b2b-acceso__block p {
    font-size: 1.7rem;
    line-height: 1.6;
    color: var(--fg-muted);
    margin: 0 0 1rem;
  }
  /* Constrain top-level reading paragraphs to a comfortable line length
     (~65ch). Cards/grids inside the block keep their own paragraph rules. */
  .b2b-acceso__block > p {
    max-width: 65ch;
  }
  .b2b-acceso__block p:last-child {
    margin-bottom: 0;
  }

  .b2b-acceso__block strong {
    color: var(--fg-strong);
    font-weight: 600;
  }

  .b2b-acceso__block a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .b2b-acceso__block a:hover {
    color: var(--fg-strong);
  }

  .b2b-acceso__list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.625rem 1.5rem;
  }
  .b2b-acceso__list li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 1.7rem;
    color: var(--fg-muted);
    line-height: 1.55;
  }
  .b2b-acceso__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.625rem;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
  }

  .b2b-acceso__note {
    margin-top: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border-left: 2px solid var(--accent);
    font-size: 1.6rem;
    line-height: 1.55;
    color: var(--fg-muted);
    max-width: 65ch;
  }

  /* Caminos: pre-aprobados vs manual */
  .b2b-acceso__paths {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }
  .b2b-acceso__path {
    padding: 1.75rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .b2b-acceso__path-tag {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.06);
    color: var(--fg-dim);
    margin-bottom: 0.875rem;
  }
  /* Card paragraphs are short blurbs in 2-col grid — slightly more compact
     than long-form body. */
  .b2b-acceso__path p {
    font-size: 1.6rem;
    line-height: 1.55;
  }
  .b2b-acceso__path-tag--fast {
    background: rgba(0, 81, 255, 0.10);
    color: var(--accent);
  }

  /* Steps numerados */
  .b2b-acceso__steps {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    counter-reset: b2b-step;
  }
  .b2b-acceso__step {
    position: relative;
    padding: 1.5rem 1.25rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-align: left;
  }
  .b2b-acceso__step-num {
    position: absolute;
    top: -1.4rem;
    left: 1.5rem;
    width: 2.8rem;
    height: 2.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--accent);
    color: #ffffff;
    font-weight: 700;
    font-size: 1.5rem;
    font-family: Georgia, "Times New Roman", serif;
  }
  .b2b-acceso__step-icon {
    width: 26px;
    height: 26px;
    color: var(--accent);
    margin: 0.5rem 0 0.75rem;
    stroke-width: 1.25;
  }
  .b2b-acceso__step-title {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.3;
    margin: 0 0 0.375rem;
    color: var(--fg-strong);
  }
  .b2b-acceso__step-desc {
    font-size: 1.6rem;
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0;
  }

  /* Features dentro */
  .b2b-acceso__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .b2b-acceso__feature {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .b2b-acceso__feature:last-child {
    border-bottom: none;
  }
  .b2b-acceso__feature-icon {
    width: 28px;
    height: 28px;
    color: var(--accent);
    margin-top: 0.25rem;
    stroke-width: 1.25;
    flex-shrink: 0;
  }
  .b2b-acceso__feature p {
    margin: 0;
  }

  /* FAQ */
  .b2b-acceso__faq {
    border-top: 1px solid var(--border);
    padding: 1rem 0;
    transition: padding 0.2s ease;
  }
  .b2b-acceso__faq:last-of-type {
    border-bottom: 1px solid var(--border);
  }
  .b2b-acceso__faq summary {
    cursor: pointer;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--fg-strong);
    list-style: none;
    position: relative;
    padding-right: 3rem;
    line-height: 1.3;
  }
  .b2b-acceso__faq summary::-webkit-details-marker {
    display: none;
  }
  .b2b-acceso__faq summary::after {
    content: "+";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 2.4rem;
    color: var(--accent);
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    transition: transform 0.2s ease;
  }
  .b2b-acceso__faq[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }
  .b2b-acceso__faq p {
    margin: 1rem 0 0;
    font-size: 1.7rem;
    line-height: 1.6;
    color: var(--fg-muted);
    max-width: 65ch;
  }
  .b2b-acceso__faq summary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* CTAs */
  .b2b-acceso__ctas-block {
    margin: 4rem 0 3rem;
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--bg-card);
    border-radius: 16px;
  }

  /* Bloque alto (sin caja) — visible above-the-fold para conversión rápida. */
  .b2b-acceso__ctas-top {
    text-align: center;
    margin: 0 0 3.5rem;
  }
  .b2b-acceso__keep-reading {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 1.5rem;
    color: var(--fg-muted);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }
  .b2b-acceso__keep-reading:hover {
    color: var(--fg-strong);
  }
  .b2b-acceso__keep-reading:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .b2b-acceso__ctas-lead {
    font-size: 1.7rem;
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0 auto 1.75rem;
    max-width: 60ch;
  }
  .b2b-acceso__ctas {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .b2b-acceso__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18rem;
    padding: 1.4rem 2.6rem;
    border-radius: 999px;
    font-size: 1.6rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .b2b-acceso__btn--primary {
    background: #0051FF;
    color: #ffffff;
    border: 1px solid #0051FF;
  }
  .b2b-acceso__btn--primary:hover {
    background: #000000;
    border-color: #000000;
    color: #ffffff;
    transform: translateY(-1px);
  }
  .b2b-acceso__btn--primary:disabled,
  .b2b-acceso__btn--primary[aria-disabled='true'] {
    background: #CCCCCC;
    border-color: #CCCCCC;
    color: #ffffff;
  }
  .b2b-acceso__btn--secondary {
    background: #ffffff;
    color: #0051FF;
    border: 1px solid #0051FF;
  }
  .b2b-acceso__btn--secondary:hover {
    background: #0051FF;
    border-color: #0051FF;
    color: #ffffff;
    transform: translateY(-1px);
  }
  .b2b-acceso__btn--secondary:disabled,
  .b2b-acceso__btn--secondary[aria-disabled='true'] {
    background: #ffffff;
    border-color: #CCCCCC;
    color: #CCCCCC;
  }
  .b2b-acceso__btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* Footer */
  .b2b-acceso__footer {
    text-align: center;
    padding: 1.75rem 0 0;
    border-top: 1px solid var(--border);
    margin-top: 1rem;
  }
  .b2b-acceso__footer-nav {
    display: flex;
    justify-content: center;
    gap: 0.875rem;
    flex-wrap: wrap;
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .b2b-acceso__footer-nav a {
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .b2b-acceso__footer-nav a:hover {
    color: var(--fg-strong);
  }
  .b2b-acceso__footer-note {
    font-size: 1.3rem;
    color: var(--fg-dim);
    margin: 0;
    letter-spacing: 0.01em;
    line-height: 1.55;
  }

  @media (max-width: 750px) {
    .b2b-acceso {
      padding: 2.5rem 1rem 3rem;
    }
    .b2b-acceso__hero {
      margin-bottom: 2.5rem;
    }
    .b2b-acceso__block {
      margin-bottom: 2.5rem;
    }
    .b2b-acceso__ctas-block {
      padding: 2rem 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .b2b-acceso__btn,
    .b2b-acceso__faq,
    .b2b-acceso__faq summary::after,
    .b2b-acceso__keep-reading,
    .b2b-acceso__btn-spinner {
      transition: none;
      animation: none;
    }
  }

  /* ========== Formulario de registro B2B ========== */
  .b2b-acceso__form-block {
    margin: 4rem 0 3rem;
    padding: 3rem 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    scroll-margin-top: 2rem;
  }
  .b2b-acceso__form-steps {
    margin: 0 0 2.5rem;
    padding: 0;
    list-style: none;
    counter-reset: form-step;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .b2b-acceso__form-steps li {
    counter-increment: form-step;
    position: relative;
    padding: 1rem 1rem 1rem 3rem;
    background: rgba(0, 0, 0, 0.04);
    border-radius: 8px;
    font-size: 1.5rem;
    line-height: 1.5;
    color: var(--fg-muted);
  }
  .b2b-acceso__form-steps li::before {
    content: counter(form-step);
    position: absolute;
    left: 0.875rem;
    top: 1rem;
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--accent);
    color: #ffffff;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 700;
    font-size: 1.3rem;
  }
  .b2b-acceso__form-steps strong {
    color: var(--fg-strong);
    font-weight: 600;
  }

  .b2b-acceso__form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .b2b-acceso__form-banner {
    padding: 1.25rem 1.5rem;
    background: rgba(220, 38, 38, 0.08);
    border-left: 3px solid #dc2626;
    border-radius: 4px;
    color: #991b1b;
    font-size: 1.5rem;
    line-height: 1.5;
  }
  .b2b-acceso__form-banner--success {
    background: rgba(0, 81, 255, 0.08);
    border-left-color: var(--accent);
    color: var(--fg-strong);
  }
  .b2b-acceso__form-banner a {
    color: inherit;
    text-decoration: underline;
  }

  .b2b-acceso__fieldset {
    border: 0;
    padding: 0;
    margin: 0;
  }
  .b2b-acceso__fieldset-legend {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--fg-strong);
    margin: 0 0 1.25rem;
    padding: 0;
    letter-spacing: -0.005em;
  }
  .b2b-acceso__form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem 1.25rem;
  }
  .b2b-acceso__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .b2b-acceso__field--wide {
    grid-column: 1 / -1;
  }
  .b2b-acceso__field label {
    font-size: 1.4rem;
    color: var(--fg-muted);
    letter-spacing: 0.01em;
  }
  .b2b-acceso__req {
    color: var(--accent);
  }
  .b2b-acceso__optional {
    color: var(--fg-dim);
    font-size: 0.875em;
  }
  .b2b-acceso__field input,
  .b2b-acceso__field select {
    width: 100%;
    padding: 1rem 1.125rem;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--fg-strong);
    font-family: inherit;
    font-size: 1.6rem;
    line-height: 1.5;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .b2b-acceso__field input:hover,
  .b2b-acceso__field select:hover {
    border-color: rgba(0, 0, 0, 0.25);
  }
  .b2b-acceso__field input:focus,
  .b2b-acceso__field select:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
    background: rgba(0, 81, 255, 0.04);
  }
  .b2b-acceso__field input[aria-invalid="true"],
  .b2b-acceso__field select[aria-invalid="true"] {
    border-color: #dc2626;
  }
  .b2b-acceso__field-error {
    font-size: 1.3rem;
    color: #991b1b;
    line-height: 1.4;
  }

  .b2b-acceso__terms {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.25rem 1.5rem;
    background: rgba(0, 0, 0, 0.04);
    border-radius: 8px;
  }
  .b2b-acceso__terms input[type="checkbox"] {
    margin-top: 0.25rem;
    flex-shrink: 0;
    width: 1.6rem;
    height: 1.6rem;
    accent-color: var(--accent);
  }
  .b2b-acceso__terms label {
    font-size: 1.5rem;
    line-height: 1.55;
    color: var(--fg-muted);
    cursor: pointer;
  }
  .b2b-acceso__terms a {
    color: var(--accent);
    text-decoration: underline;
  }

  .b2b-acceso__btn--submit {
    align-self: flex-start;
    min-width: 22rem;
    position: relative;
  }
  .b2b-acceso__btn--submit:disabled {
    cursor: not-allowed;
    transform: none;
  }
  .b2b-acceso__btn-spinner {
    display: inline-block;
    width: 1.4rem;
    height: 1.4rem;
    margin-left: 0.875rem;
    border: 2px solid rgba(0, 0, 0, 0.2);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: b2b-acceso-spin 0.8s linear infinite;
    vertical-align: -0.2rem;
  }
  /* Browser user-agent [hidden] { display:none } pierde specificity vs el
     selector de clase de arriba. Forzamos display:none cuando el atributo
     hidden está presente. */
  .b2b-acceso__btn-spinner[hidden] {
    display: none;
  }
  @keyframes b2b-acceso-spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 750px) {
    .b2b-acceso__form-block {
      padding: 2rem 1.25rem;
    }
    .b2b-acceso__btn--submit {
      width: 100%;
      min-width: 0;
    }
  }
</style>

<script>
  // i18n bundle inyectado antes del script defer del asset para garantizar
  // disponibilidad de window.LEDSC4_I18N.acceso_form cuando se ejecuta el IIFE.
  window.LEDSC4_I18N = window.LEDSC4_I18N || {};
  // ?dest= (2026-06-10): el gate manda aquí a los anónimos conservando el
  // destino original (enlace compartido a un producto, etc.). Si viene un
  // dest válido (ruta relativa, sin '//' para evitar open redirect),
  // reescribimos el return_to de los CTAs de login para que un usuario
  // aprobado aterrice donde quería ir tras el OTP.
  (function () {
    try {
      var dest = new URLSearchParams(window.location.search).get('dest');
      if (!dest || dest.charAt(0) !== '/' || dest.indexOf('//') === 0) return;
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('a[href*="/customer_authentication/login"]').forEach(function (a) {
          var url = new URL(a.getAttribute('href'), window.location.origin);
          url.searchParams.set('return_to', dest);
          a.setAttribute('href', url.pathname + url.search);
        });
      });
    } catch (e) { /* dest es mejora opcional; nunca romper la landing */ }
  })();
  // locale_prefix: '' en home, '/fr' en /fr (ver hotfix doc). Consumers
  // en JS hacen `LOCALE_PREFIX + '/path/X'` con slash inicial al path.
  window.LEDSC4_I18N.locale_prefix = {{ locale_prefix | json }};
  {%- comment -%}
    login_url_full (Sprint 3.5): construye el URL de login outcome (b)+
    para inyectarlo en email_exists_html via t: login_url:. Si en QA
    real falla `?locale=`, eliminar SOLO el sufijo `&locale=...` de la
    línea de abajo — return_to con prefijo se mantiene.

    return_to → /pages/completar-registro (2026-06-10): el 409 suele ser
    una cuenta fantasma (newsletter/alta nativa) sin datos B2B; aterrizar
    ahí cierra el ciclo directamente. La página maneja todos los estados:
    aprobado/rechazado ven "cuenta ya gestionada", el resto el form.
  {%- endcomment -%}
  {%- assign exists_return_to = locale_prefix | append: '/pages/completar-registro' | url_encode -%}
  {%- assign login_url_full = '/customer_authentication/login?return_to=' | append: exists_return_to | append: '&locale=' | append: request.locale.iso_code -%}
  window.LEDSC4_I18N.acceso_form = {
    err: {
      required: {{ 'ledsc4.acceso.form.err.required' | t | json }},
      email:    {{ 'ledsc4.acceso.form.err.email' | t | json }},
      nif:        {{ 'ledsc4.acceso.form.err.nif' | t | json }},
      nif_format: {{ 'ledsc4.acceso.form.err.nif_format' | t | json }},
      terms:      {{ 'ledsc4.acceso.form.err.terms' | t | json }}
    },
    submit:         {{ 'ledsc4.acceso.form.submit' | t | json }},
    submit_loading: {{ 'ledsc4.acceso.form.submit_loading' | t | json }},
    banner: {
      config_missing:           {{ 'ledsc4.acceso.form.banner.config_missing' | t | json }},
      email_exists_html:        {{ 'ledsc4.acceso.form.banner.email_exists_html' | t: login_url: login_url_full | json }},
      signature_expired_html:   {{ 'ledsc4.acceso.form.banner.signature_expired_html' | t | json }},
      service_unavailable_html: {{ 'ledsc4.acceso.form.banner.service_unavailable_html' | t | json }},
      generic_fallback:         {{ 'ledsc4.acceso.form.banner.generic_fallback' | t | json }},
      network_error:            {{ 'ledsc4.acceso.form.banner.network_error' | t | json }}
    }
  };
</script>
<script src="{{ 'b2b-register-v2.js' | asset_url }}" defer></script>

