{% comment %}
  Header minimalista para contextos B2B sin catálogo:
    - Usuarios anónimos (páginas legales, etc.)
    - Customers 'pendiente' (en /pages/cuenta-en-revision)
    - Customers 'rechazado' (en /pages/cuenta-rechazada)

  Solo: logo a la izquierda + login/logout a la derecha. Sin menú de
  navegación comercial (evita filtrar categorías a no-aprobados).
{% endcomment %}

<header class="b2b-header-simple" role="banner">
  <div class="b2b-header-simple__inner">
    <a href="/" class="b2b-header-simple__brand" aria-label="Inicio">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 160 }}"
          alt="{{ shop.name | escape }}"
          width="{{ section.settings.logo_width | default: 120 }}"
          height="auto"
          loading="eager"
        >
      {%- else -%}
        <span class="b2b-header-simple__brand-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <nav class="b2b-header-simple__nav" aria-label="Cuenta">
      {%- if customer -%}
        <span class="b2b-header-simple__email" title="{{ customer.email }}">
          {{ customer.first_name | default: customer.email | truncate: 24 }}
        </span>
        <a href="/account/logout" class="b2b-header-simple__link">
          Cerrar sesión
        </a>
      {%- else -%}
        <a href="/account/login" class="b2b-header-simple__link">
          Iniciar sesión
        </a>
      {%- endif -%}
    </nav>
  </div>
</header>

<style>
  .b2b-header-simple {
    border-bottom: 1px solid rgba(15, 18, 23, 0.08);
    background: #fff;
    padding: 0.875rem 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  .b2b-header-simple__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .b2b-header-simple__brand {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
  }
  .b2b-header-simple__brand img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  .b2b-header-simple__brand-text {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: rgba(15, 18, 23, 0.95);
  }
  .b2b-header-simple__nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .b2b-header-simple__email {
    font-size: 0.8125rem;
    color: rgba(15, 18, 23, 0.6);
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .b2b-header-simple__link {
    color: rgba(15, 18, 23, 0.85);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.5rem 0.875rem;
    border-radius: 0.375rem;
    transition: background-color 0.15s ease;
  }
  .b2b-header-simple__link:hover {
    background: rgba(15, 18, 23, 0.05);
  }
  @media (max-width: 480px) {
    .b2b-header-simple__email {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "B2B Header Simple",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Ancho del logo (px)",
      "min": 60,
      "max": 240,
      "step": 10,
      "default": 120
    }
  ]
}
{% endschema %}
