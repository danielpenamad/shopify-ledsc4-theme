{%- comment -%}
  B2B · Fase D — detalle de una solicitud concreta.
  URL: /pages/solicitud-detalle?ref=DXXXX
  Fetch vía list-order-requests edge function con ?ref=.
{%- endcomment -%}

{%- liquid
  assign now_ts = 'now' | date: '%s'
  assign customer_gid = 'gid://shopify/Customer/' | append: customer.id
  assign hmac_payload = customer_gid | append: ':' | append: now_ts
  assign hmac_sig = hmac_payload | hmac_sha256: settings.order_request_hmac_secret
-%}

<style>
  .b2b-detalle { max-width: 960px; margin: 0 auto; padding: 48px 24px; font-family: var(--font-body-family); font-size: 1.5rem; line-height: 1.55; }
  .b2b-detalle__back { display: inline-block; color: #666; text-decoration: underline; font-size: 1.4rem; margin-bottom: 20px; }
  .b2b-detalle h1 { font-family: var(--font-heading-family); font-size: 3rem; margin: 0 0 16px 0; letter-spacing: -0.01em; line-height: 1.15; }
  .b2b-detalle__meta { display: flex; gap: 24px; flex-wrap: wrap; align-items: center; margin: 20px 0 36px 0; color: #666; font-size: 1.4rem; }
  .b2b-detalle__status { display: inline-block; padding: 6px 14px; border-radius: 12px; font-size: 1.15rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .b2b-detalle__status--pendiente-revision { background: #fef3c7; color: #92400e; }
  .b2b-detalle__status--en-tramite { background: #dbeafe; color: #1e40af; }
  .b2b-detalle__status--confirmada { background: #d1fae5; color: #065f46; }
  .b2b-detalle__status--cancelada { background: #f3f4f6; color: #6b7280; }
  .b2b-detalle__table { width: 100%; border-collapse: collapse; margin: 0 0 32px 0; font-size: 1.4rem; }
  .b2b-detalle__table th, .b2b-detalle__table td { padding: 16px 12px; text-align: left; border-bottom: 1px solid #eee; }
  .b2b-detalle__table th { font-weight: 600; color: #666; text-transform: uppercase; font-size: 1.1rem; letter-spacing: 0.05em; }
  .b2b-detalle__table td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .b2b-detalle__totals { background: #fafaf7; padding: 24px 28px; border-radius: 6px; margin: 0 0 32px 0; }
  .b2b-detalle__totals .row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 1.5rem; }
  .b2b-detalle__totals .row--big { font-weight: 600; font-size: 1.7rem; border-top: 1px solid #e0e0e0; margin-top: 10px; padding-top: 14px; }
  .b2b-detalle__note { background: #fff8e1; border-left: 3px solid #d4a84a; padding: 20px 24px; margin: 0 0 32px 0; font-style: italic; color: #555; font-size: 1.4rem; line-height: 1.6; border-radius: 4px; }
  .b2b-detalle__note-label { font-size: 1.1rem; color: #666; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 10px 0; font-style: normal; }
  .b2b-detalle__loading { text-align: center; padding: 80px 24px; color: #666; font-size: 1.5rem; }
</style>

<div class="b2b-detalle">
  <a href="/pages/mis-solicitudes" class="b2b-detalle__back">← Mis solicitudes</a>

  <div id="b2b-detalle-loading" class="b2b-detalle__loading">Cargando solicitud…</div>
  <div id="b2b-detalle-content" style="display:none;"></div>
</div>

<script>
  (function () {
    const ENDPOINT = {{ settings.list_order_requests_endpoint | json }};
    const CUSTOMER_ID = {{ customer_gid | json }};
    const TIMESTAMP = {{ now_ts | json }};
    const SIGNATURE = {{ hmac_sig | json }};

    const params = new URLSearchParams(window.location.search);
    const REF = params.get('ref');

    const loadingEl = document.getElementById('b2b-detalle-loading');
    const contentEl = document.getElementById('b2b-detalle-content');

    const STATUS_LABELS = {
      'pendiente-revision': 'En revisión',
      'en-tramite': 'En trámite',
      'confirmada': 'Confirmada',
      'cancelada': 'Cancelada',
    };

    function fmtDate(iso) {
      const d = new Date(iso);
      return d.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    function fmtMoney(amount, currency) {
      const n = Number.parseFloat(amount);
      if (!Number.isFinite(n)) return amount;
      return n.toLocaleString('es-ES', { style: 'currency', currency: currency || 'EUR', minimumFractionDigits: 2 });
    }

    function escapeHtml(s) {
      if (s == null) return '';
      return String(s).replace(/[&<>\"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    async function load() {
      if (!REF) {
        loadingEl.textContent = 'Falta el parámetro ref en la URL.';
        return;
      }

      const url = new URL(ENDPOINT);
      url.searchParams.set('customerId', CUSTOMER_ID);
      url.searchParams.set('timestamp', TIMESTAMP);
      url.searchParams.set('signature', SIGNATURE);
      url.searchParams.set('ref', REF);

      let data;
      try {
        data = await fetch(url.toString()).then((r) => r.json());
      } catch (e) {
        loadingEl.textContent = 'Error cargando la solicitud: ' + e.message;
        return;
      }

      if (data.error === 'not_found') {
        loadingEl.textContent = 'Solicitud no encontrada o no es tuya.';
        return;
      }
      if (data.error) {
        loadingEl.textContent = 'Error: ' + data.error;
        return;
      }

      loadingEl.style.display = 'none';
      contentEl.style.display = 'block';

      const statusClass = 'b2b-detalle__status--' + data.status;
      const statusLabel = STATUS_LABELS[data.status] || data.status;

      const cbmAttr = (data.customAttributes || []).find((a) => a.key === 'cbm_total');
      const cbmTotal = cbmAttr ? cbmAttr.value : null;

      const linesHtml = (data.lineItems || []).map((li) => {
        const variant = li.variantTitle && li.variantTitle !== 'Default Title' ? `<br><small style="color:#888;">${escapeHtml(li.variantTitle)}</small>` : '';
        const sku = li.sku ? `<br><small style="color:#999;">SKU: ${escapeHtml(li.sku)}</small>` : '';
        return `<tr>
          <td><strong>${escapeHtml(li.title)}</strong>${variant}${sku}</td>
          <td class="num">${li.quantity}</td>
          <td class="num">${fmtMoney(li.unitPrice.amount, li.unitPrice.currencyCode)}</td>
          <td class="num"><strong>${fmtMoney(li.totalPrice.amount, li.totalPrice.currencyCode)}</strong></td>
        </tr>`;
      }).join('');

      const noteHtml = data.note
        ? `<div class="b2b-detalle__note"><div class="b2b-detalle__note-label">Tu comentario</div>${escapeHtml(data.note)}</div>`
        : '';

      contentEl.innerHTML = `
        <h1>Solicitud ${escapeHtml(data.name)}</h1>
        <div class="b2b-detalle__meta">
          <span>${fmtDate(data.createdAt)}</span>
          <span class="b2b-detalle__status ${statusClass}">${statusLabel}</span>
        </div>

        <table class="b2b-detalle__table">
          <thead>
            <tr><th>Producto</th><th class="num">Uds.</th><th class="num">Precio unit.</th><th class="num">Subtotal</th></tr>
          </thead>
          <tbody>${linesHtml}</tbody>
        </table>

        <div class="b2b-detalle__totals">
          <div class="row"><span>Importe estimado (sin IVA ni portes)</span><span>${fmtMoney(data.totalPrice)}</span></div>
          ${cbmTotal ? `<div class="row"><span>CBM total</span><span>${cbmTotal} m³</span></div>` : ''}
        </div>

        ${noteHtml}

        <p style="color:#666;font-size:0.85rem;line-height:1.5;margin-top:32px;">Las solicitudes no se pueden editar ni cancelar desde aquí. Si necesitas hacer cambios, escribe al equipo comercial citando la referencia.</p>
      `;
    }

    load();
  })();
</script>

{% schema %}
{
  "name": "B2B Solicitud detalle",
  "settings": []
}
{% endschema %}
