{% comment %}
  Página informativa + form /pages/acceso-instalador.

  Landing de captación masiva para instaladores (Fase 2, 2026-07). Copia de
  main-acceso-profesional.liquid (distribuidor) con 3 diferencias:
    1. Sin campo "Razón social / empresa" — el instalador no tiene Company
       por decisión de negocio (ver flows/W1-walkthrough.md, Rama Falso).
    2. NIF opcional (badge, sin `required`).
    3. Código postal obligatorio (compartido con el form de distribuidor).

  El hidden `sector` va fijo a "instalador" (en vez de "otro" como en el
  form de distribuidor). El enrutado real de rol NO ocurre aquí: TODO
  registro que llega por esta landing pasa igual por Shopify Flow W1
  (whitelist check). Si el email coincide con la whitelist, la persona
  entra como distribuidor con Company (mismo criterio para todos); si no
  coincide (el caso normal en esta landing), W1 auto-aprueba como
  instalador sin Company. Ver flows/W1-walkthrough.md.

  Mismo backend que la landing de distribuidor: edge function
  `register-b2b-customer` + `assets/b2b-register-v2.js` (genérico, sin
  cambios de por-landing salvo la relajación empresa/nif cuando
  sector === "instalador").

  Copy definitivo cargado en es/en/fr (2026-07). Namespace i18n:
  `ledsc4.acceso_instalador.*` para contenido editorial propio, más
  `ledsc4.acceso.form.*` compartido con distribuidor para mecánica de
  formulario (labels de campo, errores, banners). de/it/pt-PT caen a
  fallback: la landing solo es visible en es/en/fr esta fase.

  Gate: /pages/acceso-instalador debe añadirse a gate_exempt_paths en
  layout/theme.liquid para que sea pública (igual que acceso-profesional).

  Nomenclatura BEM: reutiliza b2b-acceso__* (mismo <style>, duplicado
  intacto — páginas hermanas que no se cargan a la vez, mismo patrón que
  main-completar-registro.liquid).
{% endcomment %}

{%- liquid
  assign locale_prefix = routes.root_url
  if locale_prefix == '/'
    assign locale_prefix = ''
  endif
-%}
{%- assign login_return_to = routes.root_url | url_encode -%}

<section
  class="b2b-acceso"
  aria-labelledby="b2b-acceso-instalador-heading"
  style="--b2b-acceso-pad-top: {{ section.settings.padding_top | default: 64 }}px; --b2b-acceso-pad-bottom: {{ section.settings.padding_bottom | default: 80 }}px;"
>

  {%- if section.settings.show_logo_header -%}
    <header class="b2b-acceso__brand">
      {%- if shop.brand.logo != blank -%}
        <img
          src="{{ shop.brand.logo | image_url: width: 360 }}"
          alt="{{ shop.name | escape }}"
          width="160"
          height="auto"
          loading="eager"
        >
      {%- else -%}
        <span class="b2b-acceso__brand-wordmark">LedsC4 <em>Outlet</em></span>
      {%- endif -%}
    </header>
  {%- endif -%}

  <div class="b2b-acceso__hero">
    <p class="b2b-acceso__eyebrow">{{ 'ledsc4.acceso_instalador.hero.eyebrow' | t }}</p>
    <h1 id="b2b-acceso-instalador-heading" class="b2b-acceso__heading">
      {{ 'ledsc4.acceso_instalador.hero.heading_html' | t }}
    </h1>
    <p class="b2b-acceso__lead">
      {{ 'ledsc4.acceso_instalador.hero.lead' | t }}
    </p>
  </div>

  <div class="b2b-acceso__ctas-top">
    <div class="b2b-acceso__ctas">
      <a href="#registro" class="b2b-acceso__btn b2b-acceso__btn--primary">
        {{ 'ledsc4.common.cta.solicitar_acceso' | t }}
      </a>
      <a href="/customer_authentication/login?return_to={{ login_return_to }}&locale={{ request.locale.iso_code }}" class="b2b-acceso__btn b2b-acceso__btn--secondary">
        {{ 'ledsc4.common.cta.login_existente' | t }}
      </a>
    </div>
    <a href="#como-funciona-instalador" class="b2b-acceso__keep-reading">
      {{ 'ledsc4.acceso_instalador.keep_reading' | t }}
    </a>
  </div>

  <article class="b2b-acceso__block" aria-labelledby="b2b-acceso-instalador-que-es">
    <h2 id="b2b-acceso-instalador-que-es" class="b2b-acceso__h2">{{ 'ledsc4.acceso_instalador.que_es.heading' | t }}</h2>
    <p>{{ 'ledsc4.acceso_instalador.que_es.body_html' | t }}</p>
  </article>

  <article id="como-funciona-instalador" class="b2b-acceso__block" aria-labelledby="b2b-acceso-instalador-como">
    <h2 id="b2b-acceso-instalador-como" class="b2b-acceso__h2">{{ 'ledsc4.acceso_instalador.como.heading' | t }}</h2>
    <p>{{ 'ledsc4.acceso_instalador.como.intro_html' | t }}</p>
  </article>

  <article class="b2b-acceso__block" aria-labelledby="b2b-acceso-instalador-dentro">
    <h2 id="b2b-acceso-instalador-dentro" class="b2b-acceso__h2">{{ 'ledsc4.acceso_instalador.dentro.heading' | t }}</h2>
    <p>{{ 'ledsc4.acceso_instalador.dentro.body_html' | t }}</p>
  </article>

  <article class="b2b-acceso__block" aria-labelledby="b2b-acceso-instalador-faq">
    <h2 id="b2b-acceso-instalador-faq" class="b2b-acceso__h2">{{ 'ledsc4.acceso_instalador.faq.heading' | t }}</h2>

    <details class="b2b-acceso__faq">
      <summary>{{ 'ledsc4.acceso_instalador.faq.q1_summary' | t }}</summary>
      <p>{{ 'ledsc4.acceso_instalador.faq.q1_body' | t }}</p>
    </details>

    <details class="b2b-acceso__faq">
      <summary>{{ 'ledsc4.acceso_instalador.faq.q2_summary' | t }}</summary>
      <p>{{ 'ledsc4.acceso_instalador.faq.q2_body' | t }}</p>
    </details>

    <details class="b2b-acceso__faq">
      <summary>{{ 'ledsc4.acceso_instalador.faq.q3_summary' | t }}</summary>
      <p>{{ 'ledsc4.acceso_instalador.faq.q3_body' | t }}</p>
    </details>
  </article>

  <div class="b2b-acceso__ctas-block">
    <p class="b2b-acceso__ctas-lead">{{ 'ledsc4.acceso_instalador.ctas_lead' | t }}</p>
    <div class="b2b-acceso__ctas">
      <a href="#registro" class="b2b-acceso__btn b2b-acceso__btn--primary">
        {{ 'ledsc4.common.cta.solicitar_acceso' | t }}
      </a>
      <a href="/customer_authentication/login?return_to={{ login_return_to }}&locale={{ request.locale.iso_code }}" class="b2b-acceso__btn b2b-acceso__btn--secondary">
        {{ 'ledsc4.common.cta.login_existente' | t }}
      </a>
    </div>
  </div>

  {%- comment -%}
    Form de registro instalador. Mismo backend, mismo HMAC, misma edge
    function que la landing de distribuidor — ver comentario equivalente
    en main-acceso-profesional.liquid para el detalle de firma.
  {%- endcomment -%}
  {%- assign register_now_ts = 'now' | date: '%s' -%}
  {%- assign register_nonce_seed = register_now_ts | append: ':' | append: section.id | append: ':' | append: shop.id -%}
  {%- assign register_nonce = register_nonce_seed | sha256 | slice: 0, 24 -%}
  {%- assign register_hmac_payload = register_now_ts | append: ':' | append: register_nonce -%}
  {%- assign register_hmac_sig = register_hmac_payload | hmac_sha256: shop.metafields.b2b.hmac_secret.value -%}

  <section id="registro" class="b2b-acceso__form-block" aria-labelledby="b2b-acceso-instalador-form-heading">
    <h2 id="b2b-acceso-instalador-form-heading" class="b2b-acceso__h2">{{ 'ledsc4.acceso.form.heading' | t }}</h2>
    <ol class="b2b-acceso__form-steps">
      <li>{{ 'ledsc4.acceso_instalador.form.step1_html' | t }}</li>
      <li>{{ 'ledsc4.acceso_instalador.form.step2_html' | t }}</li>
      <li>{{ 'ledsc4.acceso_instalador.form.step3_html' | t }}</li>
    </ol>

    <form
      id="b2b-registro-form"
      class="b2b-acceso__form"
      data-endpoint="{{ settings.register_b2b_endpoint }}"
      novalidate
      onsubmit="return false;"
    >
      <input type="hidden" name="timestamp" value="{{ register_now_ts }}">
      <input type="hidden" name="nonce" value="{{ register_nonce }}">
      <input type="hidden" name="signature" value="{{ register_hmac_sig }}">

      <div id="b2b-registro-banner" class="b2b-acceso__form-banner" hidden role="alert"></div>

      <fieldset class="b2b-acceso__fieldset">
        <legend class="b2b-acceso__fieldset-legend">{{ 'ledsc4.acceso.form.legend_personales' | t }}</legend>
        <div class="b2b-acceso__form-grid">
          <div class="b2b-acceso__field">
            <label for="reg-nombre">{{ 'ledsc4.acceso.form.label_nombre' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            <input type="text" name="nombre" id="reg-nombre" autocomplete="given-name" required maxlength="100">
            <span class="b2b-acceso__field-error" data-field="nombre" hidden></span>
          </div>
          <div class="b2b-acceso__field">
            <label for="reg-apellidos">{{ 'ledsc4.acceso.form.label_apellidos' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            <input type="text" name="apellidos" id="reg-apellidos" autocomplete="family-name" required maxlength="100">
            <span class="b2b-acceso__field-error" data-field="apellidos" hidden></span>
          </div>
          <div class="b2b-acceso__field">
            <label for="reg-email">{{ 'ledsc4.acceso.form.label_email' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
            <input type="email" name="email" id="reg-email" autocomplete="email" required maxlength="254" inputmode="email">
            <span class="b2b-acceso__field-error" data-field="email" hidden></span>
          </div>
          <div class="b2b-acceso__field">
            <label for="reg-telefono">{{ 'ledsc4.acceso.form.label_telefono' | t }}</label>
            <input type="tel" name="telefono" id="reg-telefono" autocomplete="tel" maxlength="30" inputmode="tel">
            <span class="b2b-acceso__field-error" data-field="telefono" hidden></span>
          </div>
        </div>
      </fieldset>

      <fieldset class="b2b-acceso__fieldset">
        <legend class="b2b-acceso__fieldset-legend">{{ 'ledsc4.acceso_instalador.form.legend_fiscal' | t }}</legend>
        <div class="b2b-acceso__form-grid">
          <div class="b2b-acceso__field">
            <label for="reg-nif">{{ 'ledsc4.acceso.form.label_nif' | t }} <span class="b2b-acceso__optional">{{ 'ledsc4.common.form.optional' | t }}</span></label>
            <input type="text" name="nif" id="reg-nif" maxlength="20" autocapitalize="characters" spellcheck="false">
            <span class="b2b-acceso__field-error" data-field="nif" hidden></span>
          </div>
          {%- comment -%}
            Hidden sector="instalador" — a diferencia del form de
            distribuidor (hidden "otro"). register-b2b-customer relaja
            empresa/nif a opcionales cuando sector === "instalador".
          {%- endcomment -%}
          <input type="hidden" name="sector" value="instalador">
