{%- comment -%}
  B2B · Fase D — dashboard post-login en /account.
  Reemplaza el main-account de Dawn con una vista B2B minimal con
  los CTAs principales (catalogo, mis solicitudes) y logout.

  ⚠️ NO SE RENDERIZA con "New customer accounts" (el default en 2026):
  Shopify hostea /account en shopify.com/<shop>/account, ignorando el
  theme. Este template solo se vería si la tienda cambia a "Classic
  customer accounts" en Settings.

  Alternativa adoptada (Fase D post-launch, opción E): ocultamos /account
  del flujo user-facing. Todos los CTAs linkan directos a /pages/
  mis-solicitudes (o /customer_authentication/login?return_to=
  %2Fpages%2Fmis-solicitudes para no logueados — el endpoint que sí
  respeta el redirect post-login con new customer accounts; /account/login
  ignora la querystring y manda al hosted /account/orders).
  Ver docs/backoffice-solicitudes.md.
{%- endcomment -%}

{%- liquid
  # locale_prefix: '' en home, '/fr' en /fr, etc. routes.root_url devuelve
  # '/' en home y '/fr' en locales alternos (sin trailing slash); normalizamos
  # a vacío en home para que la concat con paths que empiezan por '/' sea
  # correcta en ambos contextos.
  assign locale_prefix = routes.root_url
  if locale_prefix == '/'
    assign locale_prefix = ''
  endif

  assign greeting_fallback = 'ledsc4.common.greeting.fallback_bienvenido' | t
  assign greeting_name = customer.first_name | default: customer.name | default: greeting_fallback
-%}

<style>
  .b2b-account { max-width: 720px; margin: 0 auto; padding: 64px 24px; font-family: var(--font-body-family); }
  .b2b-account h1 { font-family: var(--font-heading-family); font-size: 2.25rem; margin: 0 0 8px 0; letter-spacing: -0.01em; }
  .b2b-account__hello { color: #555; font-size: 1.125rem; margin: 0 0 40px 0; line-height: 1.55; }
  .b2b-account__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-bottom: 40px; }
  .b2b-account__card { display: block; background: #fafaf7; padding: 28px 24px; border-radius: 8px; text-decoration: none; color: #1a1f27; border: 1px solid transparent; transition: border-color 0.15s ease, transform 0.15s ease; }
  .b2b-account__card:hover { border-color: #1a1f27; transform: translateY(-2px); }
  .b2b-account__card h2 { font-family: var(--font-heading-family); font-size: 1.375rem; font-weight: 500; margin: 0 0 8px 0; }
  .b2b-account__card p { font-size: 0.9375rem; color: #666; margin: 0; line-height: 1.5; }
  .b2b-account__card--primary { background: #1a1f27; color: #fff; }
  .b2b-account__card--primary h2 { color: #fff; }
  .b2b-account__card--primary p { color: #ccc; }
  .b2b-account__footer { display: flex; gap: 20px; align-items: center; padding-top: 28px; border-top: 1px solid #eee; font-size: 0.9375rem; color: #666; flex-wrap: wrap; }
  .b2b-account__footer a { color: #666; text-decoration: underline; }
  .b2b-account__footer a:hover { color: #1a1f27; }
  .b2b-account__empresa { font-size: 0.9375rem; color: #666; margin: -24px 0 32px 0; }
  .b2b-account__empresa strong { color: #1a1f27; }
</style>

<div class="b2b-account">
  <h1>{{ 'ledsc4.common.greeting.hola_name' | t: name: greeting_name }}</h1>
  <p class="b2b-account__hello">{{ 'ledsc4.account.dashboard.subheading' | t }}</p>

  {%- if customer.metafields.b2b.empresa != blank -%}
    <p class="b2b-account__empresa"><strong>{{ customer.metafields.b2b.empresa }}</strong>{% if customer.metafields.b2b.nif != blank %} · {{ customer.metafields.b2b.nif }}{% endif %}</p>
  {%- endif -%}

  {%- if customer.tags contains 'aprobado' -%}
    <div class="b2b-account__grid">
      <a href="{{ locale_prefix }}/collections/coleccion-2026" class="b2b-account__card b2b-account__card--primary">
        <h2>{{ 'ledsc4.account.dashboard.card_catalogo_title' | t }}</h2>
        <p>{{ 'ledsc4.account.dashboard.card_catalogo_desc' | t }}</p>
      </a>
      <a href="{{ locale_prefix }}/pages/mis-solicitudes" class="b2b-account__card">
        <h2>{{ 'ledsc4.common.cta.mis_solicitudes' | t }}</h2>
        <p>{{ 'ledsc4.account.dashboard.card_solicitudes_desc' | t }}</p>
      </a>
    </div>
  {%- elsif customer.tags contains 'rechazado' -%}
    <p style="font-size:1rem;color:#666;margin-bottom:32px;line-height:1.55;">{{ 'ledsc4.account.dashboard.estado_rechazado_lead' | t }} <a href="{{ locale_prefix }}/pages/cuenta-rechazada" style="color:#1a1f27;">{{ 'ledsc4.common.cta.mas_informacion_arrow' | t }}</a></p>
  {%- else -%}
    <p style="font-size:1rem;color:#666;margin-bottom:32px;line-height:1.55;">{{ 'ledsc4.account.dashboard.estado_revision_lead' | t }} <a href="{{ locale_prefix }}/pages/cuenta-en-revision" style="color:#1a1f27;">{{ 'ledsc4.common.cta.ver_estado_arrow' | t }}</a></p>
  {%- endif -%}

  <div class="b2b-account__footer">
    <span>{{ 'ledsc4.account.dashboard.session_email_html' | t: email: customer.email }}</span>
    <a href="{{ routes.account_logout_url }}">{{ 'customer.log_out' | t }}</a>
    <a href="{{ routes.root_url }}">{{ 'ledsc4.account.dashboard.volver_portal' | t }}</a>
  </div>
</div>

{% schema %}
{
  "name": "B2B Cuenta",
  "settings": []
}
{% endschema %}
