{% comment %}
  Página /pages/cuenta-en-revision
  Mostrada a customers con tag 'pendiente' cuando Locksmith los redirige
  desde el catálogo, o cuando llegan directamente.

  Muestra datos B2B del customer (para que confirme lo que nos dio) y
  un mensaje con tiempo estimado + email de contacto.
{% endcomment %}

<section class="b2b-status" aria-labelledby="b2b-status-heading">
  <div class="b2b-status__inner">
    <span class="b2b-status__badge b2b-status__badge--pending">En revisión</span>
    <h1 id="b2b-status-heading" class="b2b-status__heading">
      Estamos validando tu solicitud
    </h1>

    <p class="b2b-status__lead">
      {{- page.metafields.b2b.cuenta_revision_mensaje | default: section.settings.default_message -}}
    </p>

    {%- if customer -%}
      <div class="b2b-status__datos">
        <h2 class="b2b-status__datos-heading">Datos que nos diste</h2>
        <dl class="b2b-status__datos-list">
          {%- if customer.metafields.b2b.empresa != blank -%}
            <dt>Empresa</dt>
            <dd>{{ customer.metafields.b2b.empresa }}</dd>
          {%- endif -%}
          {%- if customer.metafields.b2b.nif != blank -%}
            <dt>NIF / CIF</dt>
            <dd>{{ customer.metafields.b2b.nif }}</dd>
          {%- endif -%}
          {%- if customer.metafields.b2b.sector != blank -%}
            <dt>Sector</dt>
            <dd>{{ customer.metafields.b2b.sector | replace: '_', ' / ' | capitalize }}</dd>
          {%- endif -%}
          <dt>Email</dt>
          <dd>{{ customer.email }}</dd>
        </dl>
        <p class="b2b-status__correct">
          ¿Ves un error? Escríbenos a
          <a href="mailto:{{ shop.metafields.b2b.email_backoffice | default: 'backoffice@ledsc4.com' }}">
            {{ shop.metafields.b2b.email_backoffice | default: 'backoffice@ledsc4.com' }}
          </a>
          antes de que aprobemos.
        </p>
      </div>
    {%- endif -%}

    <div class="b2b-status__ctas">
      <a href="/account/logout" class="b2b-status__btn b2b-status__btn--secondary">
        Cerrar sesión
      </a>
    </div>
  </div>
</section>

<style>
  .b2b-status {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: rgba(15, 18, 23, 0.95);
  }

  .b2b-status__inner {
    max-width: 560px;
    width: 100%;
    text-align: center;
  }

  .b2b-status__badge {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .b2b-status__badge--pending {
    background: rgba(230, 160, 0, 0.12);
    color: rgb(130, 85, 0);
  }

  .b2b-status__heading {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 1rem;
    letter-spacing: -0.015em;
  }

  .b2b-status__lead {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: rgba(15, 18, 23, 0.7);
    margin: 0 auto 2.5rem;
    max-width: 480px;
  }

  .b2b-status__datos {
    background: rgba(15, 18, 23, 0.03);
    border-radius: 0.75rem;
    padding: 1.5rem 2rem;
    margin: 0 0 2.5rem;
    text-align: left;
  }

  .b2b-status__datos-heading {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: rgba(15, 18, 23, 0.55);
  }

  .b2b-status__datos-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.25rem;
    margin: 0;
    font-size: 0.9375rem;
  }

  .b2b-status__datos-list dt {
    font-weight: 500;
    color: rgba(15, 18, 23, 0.55);
  }

  .b2b-status__datos-list dd {
    margin: 0;
    color: rgba(15, 18, 23, 0.9);
  }

  .b2b-status__correct {
    font-size: 0.8125rem;
    color: rgba(15, 18, 23, 0.55);
    margin: 1.25rem 0 0;
    line-height: 1.5;
  }

  .b2b-status__correct a {
    color: rgba(15, 18, 23, 0.85);
    text-decoration: underline;
  }

  .b2b-status__ctas {
    display: flex;
    justify-content: center;
  }

  .b2b-status__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .b2b-status__btn--secondary {
    background: transparent;
    color: rgba(15, 18, 23, 0.7);
    border: 1px solid rgba(15, 18, 23, 0.15);
  }

  .b2b-status__btn--secondary:hover {
    background: rgba(15, 18, 23, 0.04);
  }
</style>

{% schema %}
{
  "name": "B2B Cuenta En Revisión",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "default_message",
      "label": "Mensaje por defecto (si metafield vacío)",
      "info": "Fallback si page.metafields.b2b.cuenta_revision_mensaje está vacío.",
      "default": "El equipo de LedsC4 validará tu solicitud en un plazo de 24-48h hábiles. Te avisaremos por email cuando esté lista."
    }
  ],
  "presets": [
    {
      "name": "B2B Cuenta En Revisión"
    }
  ]
}
{% endschema %}
