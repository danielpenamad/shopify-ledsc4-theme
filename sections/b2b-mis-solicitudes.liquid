{%- comment -%}
  B2B · Fase D — historial de solicitudes del customer logeado.
  Fetch vía list-order-requests edge function (HMAC auth).
  Render cliente-side para no bloquear SSR con latencia Admin API.
{%- endcomment -%}

{%- liquid
  assign now_ts = 'now' | date: '%s'
  assign hmac_payload = customer.id | append: ':' | append: now_ts
  assign hmac_sig = hmac_payload | hmac_sha256: settings.order_request_hmac_secret
-%}

<style>
  .b2b-lista { max-width: 960px; margin: 0 auto; padding: 48px 24px; font-family: var(--font-body-family); }
  .b2b-lista h1 { font-family: var(--font-heading-family); font-size: 2rem; margin: 0 0 8px 0; letter-spacing: -0.01em; }
  .b2b-lista__lead { color: #666; margin: 0 0 32px 0; font-size: 0.95rem; line-height: 1.5; }
  .b2b-lista__table { width: 100%; border-collapse: collapse; }
  .b2b-lista__table thead th { font-size: 0.75rem; color: #666; text-transform: uppercase; letter-spacing: 0.05em; padding: 12px 8px; border-bottom: 2px solid #1a1f27; text-align: left; font-weight: 600; }
  .b2b-lista__table thead th.num { text-align: right; }
  .b2b-lista__table tbody tr { border-bottom: 1px solid #eee; cursor: pointer; }
  .b2b-lista__table tbody tr:hover { background: #fafaf7; }
  .b2b-lista__table td { padding: 16px 8px; font-size: 0.95rem; vertical-align: middle; }
  .b2b-lista__table td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .b2b-lista__table td.ref { font-family: 'Courier New', monospace; font-weight: 600; }
  .b2b-lista__status { display: inline-block; padding: 4px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .b2b-lista__status--pendiente-revision { background: #fef3c7; color: #92400e; }
  .b2b-lista__status--en-tramite { background: #dbeafe; color: #1e40af; }
  .b2b-lista__status--confirmada { background: #d1fae5; color: #065f46; }
  .b2b-lista__status--cancelada { background: #f3f4f6; color: #6b7280; }
  .b2b-lista__loading { text-align: center; padding: 60px 24px; color: #666; }
  .b2b-lista__empty { text-align: center; padding: 60px 24px; }
  .b2b-lista__empty p { color: #666; margin: 0 0 16px 0; }
  .b2b-lista__btn { display: inline-block; padding: 10px 20px; background: #1a1f27; color: #fff; text-decoration: none; border-radius: 6px; font-size: 0.95rem; font-weight: 500; }
  .b2b-lista__back { display: inline-block; margin-top: 24px; color: #666; text-decoration: underline; font-size: 0.9rem; }
</style>

<div class="b2b-lista">
  <h1>Mis solicitudes</h1>
  <p class="b2b-lista__lead">Aquí ves el estado de tus solicitudes de pedido B2B. Los precios son orientativos; la confirmación definitiva (IVA, portes, disponibilidad) la gestiona el equipo comercial tras revisar la solicitud.</p>

  <div id="b2b-lista-loading" class="b2b-lista__loading">Cargando solicitudes…</div>
  <div id="b2b-lista-content" style="display:none;"></div>

  <a href="/" class="b2b-lista__back">← Volver al portal</a>
</div>

<script>
  (function () {
    const ENDPOINT = {{ settings.list_order_requests_endpoint | json }};
    const CUSTOMER_ID = {{ customer.id | json }};
    const TIMESTAMP = {{ now_ts | json }};
    const SIGNATURE = {{ hmac_sig | json }};

    const loadingEl = document.getElementById('b2b-lista-loading');
    const contentEl = document.getElementById('b2b-lista-content');

    const STATUS_LABELS = {
      'pendiente-revision': 'En revisión',
      'en-tramite': 'En trámite',
      'confirmada': 'Confirmada',
      'cancelada': 'Cancelada',
    };

    function fmtDate(iso) {
      const d = new Date(iso);
      return d.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' });
    }

    function fmtMoney(v) {
      const n = Number.parseFloat(v);
      if (!Number.isFinite(n)) return v;
      return n.toLocaleString('es-ES', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 });
    }

    async function load() {
      const url = new URL(ENDPOINT);
      url.searchParams.set('customerId', CUSTOMER_ID);
      url.searchParams.set('timestamp', TIMESTAMP);
      url.searchParams.set('signature', SIGNATURE);

      let data;
      try {
        data = await fetch(url.toString()).then((r) => r.json());
      } catch (e) {
        loadingEl.textContent = 'Error cargando solicitudes: ' + e.message;
        return;
      }

      if (data.error) {
        loadingEl.textContent = 'Error: ' + data.error;
        return;
      }

      const items = data.items || [];
      loadingEl.style.display = 'none';
      contentEl.style.display = 'block';

      if (items.length === 0) {
        contentEl.innerHTML = '<div class="b2b-lista__empty"><p>Aún no has enviado ninguna solicitud.</p><a href="/collections/coleccion-2026" class="b2b-lista__btn">Ver catálogo</a></div>';
        return;
      }

      const rows = items.map((it) => {
        const statusClass = 'b2b-lista__status--' + it.status;
        const statusLabel = STATUS_LABELS[it.status] || it.status;
        const ref = encodeURIComponent(it.name);
        return `<tr onclick="window.location.href='/pages/solicitud-detalle?ref=${ref}'">
          <td>${fmtDate(it.createdAt)}</td>
          <td class="ref">${it.name}</td>
          <td class="num">${it.totalItems}</td>
          <td class="num">${fmtMoney(it.totalPrice)}</td>
          <td><span class="b2b-lista__status ${statusClass}">${statusLabel}</span></td>
        </tr>`;
      }).join('');

      contentEl.innerHTML = `
        <table class="b2b-lista__table">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Ref</th>
              <th class="num">Uds.</th>
              <th class="num">Importe est.</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      `;
    }

    load();
  })();
</script>

{% schema %}
{
  "name": "B2B Mis solicitudes",
  "settings": []
}
{% endschema %}
