{%- comment -%}
  B2B · Fase D — historial de solicitudes del customer logeado.

  Esta página es la LANDING POST-LOGIN para customers aprobados (los login
  links del theme llevan ?checkout_url=%2Fpages%2Fmis-solicitudes). Por
  eso muestra:

    - Saludo personalizado siempre arriba ("Hola, {empresa}").
    - Si NO tiene solicitudes → dashboard de bienvenida (snippet
      b2b-dashboard-cards) con el grid de colecciones del main-menu.
    - Si SÍ tiene → tabla con la lista, fetched client-side vía edge
      function list-order-requests (HMAC auth).

  Render cliente-side para no bloquear SSR con latencia Admin API. JS
  decide cuál de los dos estados (.b2b-lista__empty o .b2b-lista__content)
  hacer visible al recibir respuesta.
{%- endcomment -%}

{%- liquid
  assign now_ts = 'now' | date: '%s'
  assign customer_gid = 'gid://shopify/Customer/' | append: customer.id
  assign hmac_payload = customer_gid | append: ':' | append: now_ts
  assign hmac_sig = hmac_payload | hmac_sha256: settings.order_request_hmac_secret
  assign fallback_bienvenido = 'ledsc4.common.greeting.fallback_bienvenido' | t
  assign saludo = customer.metafields.b2b.empresa | default: customer.first_name | default: fallback_bienvenido

  assign iso = request.locale.iso_code
  assign locale_bcp47 = iso
  case iso
    when 'es'
      assign locale_bcp47 = 'es-ES'
    when 'fr'
      assign locale_bcp47 = 'fr-FR'
    when 'en'
      assign locale_bcp47 = 'en-GB'
    when 'de'
      assign locale_bcp47 = 'de-DE'
    when 'it'
      assign locale_bcp47 = 'it-IT'
    when 'pt-PT'
      assign locale_bcp47 = 'pt-PT'
  endcase
-%}

<section class="b2b-lista" aria-labelledby="b2b-lista-heading">

  <header class="b2b-lista__header">
    <p class="b2b-lista__eyebrow">{{ 'ledsc4.common.eyebrow.portal_b2b' | t }}</p>
    <h1 id="b2b-lista-heading" class="b2b-lista__heading">
      {{ 'ledsc4.common.greeting.hola_name' | t: name: saludo }}
    </h1>
  </header>

  <div id="b2b-lista-loading" class="b2b-lista__loading">{{ 'ledsc4.solicitudes.lista.loading' | t }}</div>

  {%- comment -%} Dashboard de bienvenida — visible cuando NO hay solicitudes. {%- endcomment -%}
  <div id="b2b-lista-empty" class="b2b-lista__empty" hidden>
    <p class="b2b-lista__empty-lead">
      {{ 'ledsc4.solicitudes.lista.empty_lead' | t }}
    </p>
    {%- render 'b2b-dashboard-cards' -%}
  </div>

  {%- comment -%} Tabla — visible cuando SÍ hay solicitudes. JS la rellena. {%- endcomment -%}
  <div id="b2b-lista-content" class="b2b-lista__content" hidden>
    <h2 class="b2b-lista__subheading">{{ 'ledsc4.solicitudes.lista.subheading' | t }}</h2>
    <div id="b2b-lista-table-wrap"></div>
  </div>
</section>

{% style %}
  .b2b-lista {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
    font-family: var(--font-ledsc4-body);
    color: rgb(var(--color-foreground));
    box-sizing: border-box;
  }
  .b2b-lista *,
  .b2b-lista *::before,
  .b2b-lista *::after { box-sizing: border-box; }

  .b2b-lista__header {
    padding: 1rem 0 2rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    margin-bottom: 2.5rem;
  }
  .b2b-lista__eyebrow {
    font-family: var(--font-ledsc4-ui);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 0.75rem;
  }
  .b2b-lista__heading {
    font-family: var(--font-ledsc4-heading);
    font-size: clamp(3.2rem, 5vw, 4.4rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .b2b-lista__loading {
    text-align: center;
    padding: 4rem 1.5rem;
    color: rgba(var(--color-foreground), 0.6);
    font-size: 1.6rem;
  }

  /* EMPTY — dashboard de bienvenida */
  .b2b-lista__empty-lead {
    font-family: var(--font-ledsc4-body);
    font-size: clamp(1.7rem, 1.8vw, 1.9rem);
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.72);
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  /* CONTENT — tabla de solicitudes */
  .b2b-lista__subheading {
    font-family: var(--font-ledsc4-heading);
    font-size: clamp(2.4rem, 3vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
    color: rgb(var(--color-foreground));
  }
  .b2b-lista__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1.6rem;
  }
  .b2b-lista__table thead th {
    font-family: var(--font-ledsc4-ui);
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.875rem 0.75rem;
    border-bottom: 2px solid rgb(var(--color-foreground));
    text-align: left;
    font-weight: 600;
  }
  .b2b-lista__table thead th.num { text-align: right; }
  .b2b-lista__table tbody tr {
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }
  .b2b-lista__table tbody tr:hover {
    background: rgba(var(--color-foreground), 0.03);
  }
  .b2b-lista__table td {
    padding: 1.125rem 0.75rem;
    font-size: 1.6rem;
    vertical-align: middle;
  }
  .b2b-lista__table td.num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .b2b-lista__table td.ref {
    font-family: var(--font-ledsc4-ui);
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: 0.02em;
  }
  .b2b-lista__status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-family: var(--font-ledsc4-ui);
    font-size: 1.2rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .b2b-lista__status--pendiente-revision { background: #fef3c7; color: #92400e; }
  .b2b-lista__status--en-tramite { background: #dbeafe; color: #1e40af; }
  .b2b-lista__status--confirmada { background: #d1fae5; color: #065f46; }
  .b2b-lista__status--cancelada { background: #f3f4f6; color: #6b7280; }

  @media (max-width: 600px) {
    .b2b-lista { padding: 1.75rem 1rem 3rem; }
    .b2b-lista__table thead { display: none; }
    .b2b-lista__table tbody tr {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.25rem 1rem;
      padding: 1rem 0;
    }
    .b2b-lista__table td { padding: 0.125rem 0; }
  }
{% endstyle %}

<script>
  (function () {
    const ENDPOINT = {{ settings.list_order_requests_endpoint | json }};
    const CUSTOMER_ID = {{ customer_gid | json }};
    const TIMESTAMP = {{ now_ts | json }};
    const SIGNATURE = {{ hmac_sig | json }};
    const LOCALE = {{ locale_bcp47 | json }};

    const T = {
      th_fecha: {{ 'ledsc4.solicitudes.lista.th_fecha' | t | json }},
      th_ref: {{ 'ledsc4.solicitudes.lista.th_ref' | t | json }},
      th_uds: {{ 'ledsc4.solicitudes.table.th_uds' | t | json }},
      th_importe_est: {{ 'ledsc4.solicitudes.lista.th_importe_est' | t | json }},
      th_estado: {{ 'ledsc4.solicitudes.lista.th_estado' | t | json }},
      load: {{ 'ledsc4.solicitudes.lista.js_errors.load' | t | json }},
      api: {{ 'ledsc4.solicitudes.lista.js_errors.api' | t | json }},
      status: {
        'pendiente-revision': {{ 'ledsc4.solicitudes.status.pendiente_revision' | t | json }},
        'en-tramite': {{ 'ledsc4.solicitudes.status.en_tramite' | t | json }},
        'confirmada': {{ 'ledsc4.solicitudes.status.confirmada' | t | json }},
        'cancelada': {{ 'ledsc4.solicitudes.status.cancelada' | t | json }},
      },
    };

    const loadingEl = document.getElementById('b2b-lista-loading');
    const emptyEl = document.getElementById('b2b-lista-empty');
    const contentEl = document.getElementById('b2b-lista-content');
    const tableWrapEl = document.getElementById('b2b-lista-table-wrap');

    function fmtDate(iso) {
      const d = new Date(iso);
      return d.toLocaleDateString(LOCALE, { day: '2-digit', month: '2-digit', year: 'numeric' });
    }

    function fmtMoney(v) {
      const n = Number.parseFloat(v);
      if (!Number.isFinite(n)) return v;
      return n.toLocaleString(LOCALE, { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 });
    }

    function showEmpty() {
      loadingEl.hidden = true;
      contentEl.hidden = true;
      emptyEl.hidden = false;
    }

    function showContent() {
      loadingEl.hidden = true;
      emptyEl.hidden = true;
      contentEl.hidden = false;
    }

    function showError(msg) {
      loadingEl.textContent = msg;
    }

    async function load() {
      const url = new URL(ENDPOINT);
      url.searchParams.set('customerId', CUSTOMER_ID);
      url.searchParams.set('timestamp', TIMESTAMP);
      url.searchParams.set('signature', SIGNATURE);

      let data;
      try {
        data = await fetch(url.toString()).then((r) => r.json());
      } catch (e) {
        showError(T.load.replace('{message}', e.message));
        return;
      }

      if (data.error) {
        showError(T.api.replace('{error}', data.error));
        return;
      }

      const items = data.items || [];

      if (items.length === 0) {
        showEmpty();
        return;
      }

      const rows = items.map((it) => {
        const statusClass = 'b2b-lista__status--' + it.status;
        const statusLabel = T.status[it.status] || it.status;
        const ref = encodeURIComponent(it.name);
        return `<tr onclick="window.location.href='/pages/solicitud-detalle?ref=${ref}'">
          <td>${fmtDate(it.createdAt)}</td>
          <td class="ref">${it.name}</td>
          <td class="num">${it.totalItems}</td>
          <td class="num">${fmtMoney(it.totalPrice)}</td>
          <td><span class="b2b-lista__status ${statusClass}">${statusLabel}</span></td>
        </tr>`;
      }).join('');

      tableWrapEl.innerHTML = `
        <table class="b2b-lista__table">
          <thead>
            <tr>
              <th>${T.th_fecha}</th>
              <th>${T.th_ref}</th>
              <th class="num">${T.th_uds}</th>
              <th class="num">${T.th_importe_est}</th>
              <th>${T.th_estado}</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      `;

      showContent();
    }

    load();
  })();
</script>

{% schema %}
{
  "name": "B2B Mis solicitudes",
  "settings": []
}
{% endschema %}
