{%- comment -%}
  B2B · Fase D — formulario de solicitud de pedido.
  Renderiza /pages/solicitud:
    1. Resumen del carrito (read-only)
    2. Textarea comentario (max 1000)
    3. Checkbox aviso IVA/portes (required)
    4. Submit -> POST al edge function submit-order-request
  Autenticacion: HMAC(customer.id:timestamp, shop.metafields.b2b.order_request_hmac_secret)
  firmado server-side por Liquid (metafield storefront:NONE). TTL 10 min.
{%- endcomment -%}

{%- liquid
  assign now_ts = 'now' | date: '%s'
  assign customer_gid = 'gid://shopify/Customer/' | append: customer.id
  assign hmac_payload = customer_gid | append: ':' | append: now_ts
  assign hmac_sig = hmac_payload | hmac_sha256: shop.metafields.b2b.order_request_hmac_secret.value

  # locale_prefix: '' en home, '/fr' en /fr — ver hotfix doc.
  assign locale_prefix = routes.root_url
  if locale_prefix == '/'
    assign locale_prefix = ''
  endif

  # Fase 2 instalador (julio 2026): ver nota en main-cart-footer.liquid.
  assign ledsc4_is_instalador = false
  if customer and customer.tags contains 'instalador'
    assign ledsc4_is_instalador = true
  endif
-%}

<style>
  .b2b-solicitud { max-width: 960px; margin: 0 auto; padding: 48px 24px; font-family: var(--font-body-family); font-size: 1.5rem; line-height: 1.55; }
  .b2b-solicitud h1 { font-family: var(--font-heading-family); font-size: 3rem; margin: 0 0 16px 0; letter-spacing: -0.01em; line-height: 1.15; }
  .b2b-solicitud__lead { color: #555; margin: 0 0 36px 0; font-size: 1.5rem; line-height: 1.6; max-width: 720px; }
  .b2b-solicitud__table { width: 100%; border-collapse: collapse; margin: 0 0 32px 0; }
  .b2b-solicitud__table th, .b2b-solicitud__table td { padding: 16px 12px; text-align: left; border-bottom: 1px solid #eee; font-size: 1.4rem; }
  .b2b-solicitud__table th { font-weight: 600; color: #666; text-transform: uppercase; font-size: 1.1rem; letter-spacing: 0.05em; }
  .b2b-solicitud__table td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .b2b-solicitud__totals { background: #fafaf7; padding: 24px 28px; border-radius: 6px; margin: 0 0 36px 0; }
  .b2b-solicitud__totals .row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 1.5rem; }
  .b2b-solicitud__totals .row--big { font-weight: 600; font-size: 1.7rem; border-top: 1px solid #e0e0e0; margin-top: 10px; padding-top: 14px; }
  .b2b-solicitud__warn { font-size: 1.3rem; color: #666; margin-top: 12px; font-style: italic; line-height: 1.5; }
  .b2b-solicitud__field { margin: 0 0 28px 0; }
  .b2b-solicitud__field label { display: block; margin-bottom: 10px; font-weight: 500; font-size: 1.4rem; }
  .b2b-solicitud__field textarea { width: 100%; min-height: 160px; padding: 16px; border: 1px solid #ccc; border-radius: 4px; font-family: inherit; font-size: 1.4rem; line-height: 1.55; resize: vertical; }
  .b2b-solicitud__hint { font-size: 1.3rem; color: #666; margin: 8px 0 0 0; line-height: 1.5; }
  .b2b-solicitud__checkbox { display: flex; align-items: flex-start; gap: 14px; padding: 20px 24px; background: #f0f5ff; border-left: 3px solid var(--color-ledsc4-accent); margin: 0 0 32px 0; border-radius: 4px; }
  .b2b-solicitud__checkbox input { margin-top: 5px; flex-shrink: 0; width: 20px; height: 20px; }
  .b2b-solicitud__checkbox label { font-size: 1.4rem; line-height: 1.55; cursor: pointer; }
  .b2b-solicitud__actions { display: flex; gap: 20px; align-items: center; }
  .b2b-solicitud__submit { background: #0051FF; color: #fff; border: 1px solid #0051FF; padding: 18px 40px; border-radius: 6px; font-size: 1.5rem; font-weight: 500; cursor: pointer; font-family: inherit; }
  .b2b-solicitud__submit:hover { background: #000; border-color: #000; }
  .b2b-solicitud__submit:disabled { background: #CCCCCC; border-color: #CCCCCC; color: #fff; cursor: not-allowed; }
  .b2b-solicitud__cancel { color: #666; text-decoration: underline; font-size: 1.4rem; }
  .b2b-solicitud__error { background: #fef2f2; border-left: 3px solid #dc2626; padding: 18px 22px; margin: 0 0 24px 0; color: #991b1b; font-size: 1.4rem; display: none; line-height: 1.5; border-radius: 4px; }
  .b2b-solicitud__error.visible { display: block; }
  .b2b-solicitud__empty { text-align: center; padding: 80px 24px; font-size: 1.5rem; }
</style>

<div class="b2b-solicitud">
  {%- if ledsc4_is_instalador -%}
    <h1>{{ 'ledsc4.solicitudes.form.heading_instalador' | t }}</h1>
    <p class="b2b-solicitud__lead">{{ 'ledsc4.solicitudes.form.lead_instalador' | t }}</p>
  {%- else -%}
    <h1>{{ 'ledsc4.solicitudes.form.heading' | t }}</h1>
    <p class="b2b-solicitud__lead">{{ 'ledsc4.solicitudes.form.lead' | t }}</p>
  {%- endif -%}

  {%- if cart.item_count == 0 -%}
    <div class="b2b-solicitud__empty">
      <p>{{ 'ledsc4.solicitudes.form.empty_html' | t }}</p>
    </div>
  {%- else -%}

    <div id="b2b-solicitud-error" class="b2b-solicitud__error"></div>

    <table class="b2b-solicitud__table">
      <thead>
        <tr>
          <th>{{ 'ledsc4.solicitudes.table.th_producto' | t }}</th>
          <th class="num">{{ 'ledsc4.solicitudes.table.th_uds' | t }}</th>
          <th class="num">{{ 'ledsc4.solicitudes.table.th_precio_unit' | t }}</th>
          <th class="num">{{ 'ledsc4.solicitudes.table.th_subtotal' | t }}</th>
        </tr>
      </thead>
      <tbody>
        {%- for item in cart.items -%}
          <tr>
            <td>
              {%- comment -%}
                Título prefijado con SKU vía product-display-title (PR B).
                La línea separada "SKU: ..." se eliminó por single source
                of truth: el SKU ya forma parte del título mostrado.
              {%- endcomment -%}
              <strong>{%- render 'product-display-title', product: item.product -%}</strong>
              {%- if item.variant.title != 'Default Title' -%}
                <br><small style="color:#666;">{{ item.variant.title }}</small>
              {%- endif -%}
            </td>
            <td class="num">{{ item.quantity }}</td>
            <td class="num">{{ item.price | money }}</td>
            <td class="num">{{ item.line_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>

    <div class="b2b-solicitud__totals">
      <div class="row">
        <span>{{ 'ledsc4.solicitudes.table.importe_estimado' | t }}</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      <p class="b2b-solicitud__warn">
        {%- if ledsc4_is_instalador -%}
          {{ 'ledsc4.solicitudes.form.warn_instalador' | t }}
        {%- else -%}
          {{ 'ledsc4.solicitudes.form.warn' | t }}
        {%- endif -%}
      </p>
    </div>

    <form id="b2b-solicitud-form" onsubmit="return false;">
      <div class="b2b-solicitud__field">
        <label for="b2b-comentario">{{ 'ledsc4.solicitudes.form.comentario_label' | t }}</label>
        <textarea id="b2b-comentario" name="comentario" maxlength="1000" placeholder="{{ 'ledsc4.solicitudes.form.comentario_placeholder' | t }}"></textarea>
        <p class="b2b-solicitud__hint">{{ 'ledsc4.solicitudes.form.comentario_hint' | t }}</p>
      </div>

      <div class="b2b-solicitud__checkbox">
        <input type="checkbox" id="b2b-aviso" name="aviso" required>
        <label for="b2b-aviso">
          {{ 'ledsc4.solicitudes.form.aviso' | t }}
        </label>
      </div>

      <p class="ledsc4-fx-disclaimer caption">{{ 'ledsc4.common.currency.fx_disclaimer' | t }}</p>

      <div class="b2b-solicitud__actions">
        <button type="submit" id="b2b-submit" class="b2b-solicitud__submit">
          {%- if ledsc4_is_instalador -%}
            {{ 'ledsc4.solicitudes.form.submit_instalador' | t }}
          {%- else -%}
            {{ 'ledsc4.solicitudes.form.submit' | t }}
          {%- endif -%}
        </button>
        <a href="{{ routes.cart_url }}" class="b2b-solicitud__cancel">{{ 'ledsc4.solicitudes.form.cancel' | t }}</a>
      </div>
    </form>

    <script>
      (function () {
        const ENDPOINT = {{ settings.order_request_endpoint | json }};
        const CUSTOMER_ID = {{ customer_gid | json }};
        const TIMESTAMP = {{ now_ts | json }};
        const SIGNATURE = {{ hmac_sig | json }};
        // LOCALE_PREFIX: '' en home, '/fr' en /fr (ver hotfix doc).
        // Usos: LOCALE_PREFIX + '/path/X' (con slash inicial).
        const LOCALE_PREFIX = {{ locale_prefix | json }};
        // Currency-Display — divisa visible elegida por el visitante en el
        // switcher. Se inyecta en el payload para que submit-order-request la
        // guarde como note_attribute en el draft order ("Moneda mostrada"). El
        // draft sigue creándose en EUR (única divisa real del B2B ES); este
        // valor es informativo.
        //
        // Fuente: cookie `ledsc4_currency` ∈ {EUR,USD,GBP}, set por
        // snippets/currency-switcher.liquid. NO `cart.currency.iso_code`:
        // el B2B logueado está clavado al Market ES (EUR) y ese path
        // siempre devolvería 'EUR' aunque el usuario haya elegido USD/GBP
        // en el switcher cosmético.
        //
        // Default 'EUR' si la cookie falta o tiene un valor inesperado. El
        // edge function tiene whitelist EUR/USD/GBP → cualquier otro
        // valor → 'EUR' server-side.
        function readDisplayCurrency() {
          try {
            const m = document.cookie.match(/(?:^|; )ledsc4_currency=([^;]*)/);
            const v = m ? decodeURIComponent(m[1]) : null;
            return (v === 'USD' || v === 'GBP' || v === 'EUR') ? v : 'EUR';
          } catch (e) {
            return 'EUR';
          }
        }
        const CURRENCY_CODE = readDisplayCurrency();

        const T = {
          {%- if ledsc4_is_instalador -%}
          submit: {{ 'ledsc4.solicitudes.form.submit_instalador' | t | json }},
          {%- else -%}
          submit: {{ 'ledsc4.solicitudes.form.submit' | t | json }},
          {%- endif -%}
          submit_loading: {{ 'ledsc4.solicitudes.form.submit_loading' | t | json }},
          aviso_required: {{ 'ledsc4.solicitudes.form.js_errors.aviso_required' | t | json }},
          cart_read_failed: {{ 'ledsc4.solicitudes.form.js_errors.cart_read_failed' | t | json }},
          cart_empty: {{ 'ledsc4.solicitudes.form.js_errors.cart_empty' | t | json }},
          network: {{ 'ledsc4.solicitudes.form.js_errors.network' | t | json }},
          recent_request_suffix: {{ 'ledsc4.solicitudes.form.js_errors.recent_request_suffix' | t | json }},
          create_failed: {{ 'ledsc4.solicitudes.form.js_errors.create_failed' | t | json }},
          create_failed_unknown: {{ 'ledsc4.solicitudes.form.js_errors.create_failed_unknown' | t | json }},
        };

        const form = document.getElementById('b2b-solicitud-form');
        const submitBtn = document.getElementById('b2b-submit');
        const comentarioEl = document.getElementById('b2b-comentario');
        const avisoEl = document.getElementById('b2b-aviso');
        const errorEl = document.getElementById('b2b-solicitud-error');

        function showError(msg) {
          errorEl.textContent = msg;
          errorEl.classList.add('visible');
          submitBtn.disabled = false;
          submitBtn.textContent = T.submit;
        }

        function hideError() {
          errorEl.classList.remove('visible');
        }

        async function submit(force) {
          if (!avisoEl.checked) {
            showError(T.aviso_required);
            return;
          }
          hideError();
          submitBtn.disabled = true;
          submitBtn.textContent = T.submit_loading;

          // Lee el carrito en tiempo real (por si cambio entre render y submit)
          let cartData;
          try {
            cartData = await fetch('/cart.js').then((r) => r.json());
          } catch (e) {
            showError(T.cart_read_failed);
            return;
          }

          if (!cartData.items || !cartData.items.length) {
            showError(T.cart_empty);
            return;
          }

          const items = cartData.items.map((it) => ({
            variantId: 'gid://shopify/ProductVariant/' + it.variant_id,
            quantity: it.quantity,
          }));

          const payload = {
            customerId: CUSTOMER_ID,
            timestamp: Number(TIMESTAMP),
            signature: SIGNATURE,
            note: comentarioEl.value || '',
            items: items,
            currencyCode: readDisplayCurrency(),
            force: !!force,
          };

          let res;
          try {
            res = await fetch(ENDPOINT, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            }).then((r) => r.json());
          } catch (e) {
            showError(T.network.replace('{message}', e.message));
            return;
          }

          if (res.warning === 'recent_request') {
            const recentName = (res.recentDraft && res.recentDraft.name) || '';
            const ok = confirm(
              res.message + '\n\n' + T.recent_request_suffix.replace('{name}', recentName)
            );
            if (ok) {
              return submit(true);
            } else {
              submitBtn.disabled = false;
              submitBtn.textContent = T.submit;
              return;
            }
          }

          if (!res.ok) {
            showError(T.create_failed.replace('{error}', res.error || T.create_failed_unknown));
            return;
          }

          // Limpiar carrito cliente-side y redirigir
          try {
            await fetch('/cart/clear.js', { method: 'POST' });
          } catch (e) {
            /* no bloqueante */
          }
          const ref = encodeURIComponent(res.draftOrderName || '');
          window.location.href = LOCALE_PREFIX + '/pages/solicitud-enviada?ref=' + ref;
        }

        form.addEventListener('submit', function (ev) {
          ev.preventDefault();
          submit(false);
        });
      })();
    </script>

  {%- endif -%}
</div>

{% schema %}
{
  "name": "B2B Solicitud (form)",
  "settings": []
}
{% endschema %}
