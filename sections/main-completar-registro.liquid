                <option value="YE">{{ 'ledsc4.common.country.ye' | t }}</option>
              </select>
              <span class="b2b-acceso__field-error" data-field="pais" hidden></span>
            </div>
            <div class="b2b-acceso__field b2b-acceso__field--wide">
              <label for="comp-volumen">{{ 'ledsc4.acceso.form.label_volumen' | t }} <span class="b2b-acceso__optional">{{ 'ledsc4.common.form.optional' | t }}</span></label>
              <select name="volumen_estimado" id="comp-volumen">
                <option value="">{{ 'ledsc4.acceso.form.volumen.no_decir' | t }}</option>
                <option value="<5k">{{ 'ledsc4.acceso.form.volumen.lt_5k' | t }}</option>
                <option value="5k-25k">{{ 'ledsc4.acceso.form.volumen.5k_25k' | t }}</option>
                <option value="25k-100k">{{ 'ledsc4.acceso.form.volumen.25k_100k' | t }}</option>
                <option value=">100k">{{ 'ledsc4.acceso.form.volumen.gt_100k' | t }}</option>
                <option value="no_se">{{ 'ledsc4.acceso.form.volumen.no_se' | t }}</option>
              </select>
              <span class="b2b-acceso__field-error" data-field="volumen_estimado" hidden></span>
            </div>
          </div>
        </fieldset>

        <div class="b2b-acceso__terms">
          <input type="checkbox" name="condiciones" id="comp-terms" required>
          <label for="comp-terms">{{ 'ledsc4.acceso.form.terms_html' | t }}</label>
        </div>
        <span class="b2b-acceso__field-error" data-field="condiciones" hidden></span>

        <button type="submit" id="b2b-completar-submit" class="b2b-acceso__btn b2b-acceso__btn--primary b2b-acceso__btn--submit">
          <span class="b2b-acceso__btn-label">{{ 'ledsc4.completar.form.submit' | t }}</span>
          <span class="b2b-acceso__btn-spinner" aria-hidden="true" hidden></span>
        </button>
