                <option value="DZ">{{ 'ledsc4.common.country.dz' | t }}</option>
                <option value="AR">{{ 'ledsc4.common.country.ar' | t }}</option>
                <option value="AT">{{ 'ledsc4.common.country.at' | t }}</option>
                <option value="BS">{{ 'ledsc4.common.country.bs' | t }}</option>
                <option value="BB">{{ 'ledsc4.common.country.bb' | t }}</option>
                <option value="BH">{{ 'ledsc4.common.country.bh' | t }}</option>
                <option value="BE">{{ 'ledsc4.common.country.be' | t }}</option>
                <option value="BZ">{{ 'ledsc4.common.country.bz' | t }}</option>
                <option value="BO">{{ 'ledsc4.common.country.bo' | t }}</option>
                <option value="BA">{{ 'ledsc4.common.country.ba' | t }}</option>
