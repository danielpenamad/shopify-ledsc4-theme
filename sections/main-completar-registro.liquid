<style>
  .b2b-acceso {
    --bg: #ffffff;
    --bg-alt: #f5f5f7;
    --bg-card: rgba(0, 0, 0, 0.04);
    --fg: #000000;
    --fg-strong: #000000;
    --fg-muted: rgba(0, 0, 0, 0.72);
    --fg-dim: rgba(0, 0, 0, 0.50);
    --accent: var(--color-ledsc4-accent);
    --border: rgba(0, 0, 0, 0.10);
    background: var(--bg);
    color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    line-height: 1.6;
    padding: var(--b2b-acceso-pad-top, 64px) 1.5rem var(--b2b-acceso-pad-bottom, 80px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .b2b-acceso *, .b2b-acceso *::before, .b2b-acceso *::after { box-sizing: border-box; }
  .b2b-acceso > * { width: 100%; max-width: 780px; }

  .b2b-acceso__brand { text-align: center; margin-bottom: 2.5rem; }
  .b2b-acceso__brand img { max-width: 100%; height: auto; display: inline-block; }
  .b2b-acceso__brand-wordmark {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.4rem; font-weight: 400; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--fg);
  }
  .b2b-acceso__brand-wordmark em {
    font-style: italic; font-weight: 400; color: var(--accent);
    text-transform: none; letter-spacing: 0; font-size: 0.85em;
  }

  .b2b-acceso__hero { text-align: center; margin-bottom: 4rem; }
  .b2b-acceso__eyebrow {
    font-size: 1.4rem; font-weight: 600; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--accent); margin: 0 0 1.25rem;
  }
  .b2b-acceso__heading {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.6rem, 6vw, 6.4rem); font-weight: 400;
    line-height: 1.1; margin: 0 0 1.5rem; color: var(--fg-strong);
    letter-spacing: -0.015em;
  }
  .b2b-acceso__heading em { font-style: italic; color: var(--accent); font-weight: 400; display: block; }
  @media (min-width: 750px) { .b2b-acceso__heading em { display: inline; } }
  .b2b-acceso__lead {
    font-size: clamp(1.7rem, 1.8vw, 2.1rem); line-height: 1.55;
    color: var(--fg-muted); margin: 0 auto; max-width: 60ch;
  }

  .b2b-acceso__h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 3vw, 3.2rem); font-weight: 400;
    line-height: 1.2; margin: 0 0 1.25rem; color: var(--fg-strong);
    letter-spacing: -0.01em;
  }

  /* CTAs block (ramas A y B) */
  .b2b-acceso__ctas-block {
    margin: 2rem 0 3rem; text-align: center;
    padding: 2.5rem 1.5rem; background: var(--bg-card); border-radius: 16px;
  }
  .b2b-acceso__ctas-lead {
    font-size: 1.7rem; line-height: 1.55; color: var(--fg-muted);
    margin: 0 auto 1.75rem; max-width: 60ch;
  }
  .b2b-acceso__ctas { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .b2b-acceso__btn {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 18rem; padding: 1.4rem 2.6rem; border-radius: 999px;
    font-size: 1.6rem; font-weight: 500; text-decoration: none;
    letter-spacing: 0.01em;
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .b2b-acceso__btn--primary { background: #0051FF; color: #ffffff; border: 1px solid #0051FF; }
  .b2b-acceso__btn--primary:hover {
    background: #000000; border-color: #000000;
    color: #ffffff; transform: translateY(-1px);
  }
  .b2b-acceso__btn--primary:disabled,
  .b2b-acceso__btn--primary[aria-disabled='true'] { background: #CCCCCC; border-color: #CCCCCC; color: #ffffff; }
  .b2b-acceso__btn--secondary { background: #ffffff; color: #0051FF; border: 1px solid #0051FF; }
  .b2b-acceso__btn--secondary:hover { background: #0051FF; border-color: #0051FF; color: #ffffff; transform: translateY(-1px); }
  .b2b-acceso__btn--secondary:disabled,
  .b2b-acceso__btn--secondary[aria-disabled='true'] { background: #ffffff; border-color: #CCCCCC; color: #CCCCCC; }
  .b2b-acceso__btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

  /* Footer */
  .b2b-acceso__footer { text-align: center; padding: 1.75rem 0 0; border-top: 1px solid var(--border); margin-top: 1rem; }
  .b2b-acceso__footer-nav {
    display: flex; justify-content: center; gap: 0.875rem; flex-wrap: wrap;
    font-size: 1.5rem; margin-bottom: 0.75rem;
  }
  .b2b-acceso__footer-nav a { color: var(--fg-muted); text-decoration: none; transition: color 0.2s ease; }
  .b2b-acceso__footer-nav a:hover { color: var(--fg-strong); }
  .b2b-acceso__footer-note { font-size: 1.3rem; color: var(--fg-dim); margin: 0; letter-spacing: 0.01em; line-height: 1.55; }

  @media (max-width: 750px) {
    .b2b-acceso { padding: 2.5rem 1rem 3rem; }
    .b2b-acceso__hero { margin-bottom: 2.5rem; }
    .b2b-acceso__ctas-block { padding: 2rem 1rem; }
  }

  /* Form */
  .b2b-acceso__form-block {
    margin: 2rem 0 3rem; padding: 3rem 2rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 16px;
  }
  .b2b-acceso__form { display: flex; flex-direction: column; gap: 2rem; }
  .b2b-acceso__form-banner {
    padding: 1.25rem 1.5rem; background: rgba(220, 38, 38, 0.08);
    border-left: 3px solid #dc2626; border-radius: 4px;
    color: #991b1b; font-size: 1.5rem; line-height: 1.5;
  }
  .b2b-acceso__form-banner--success {
    background: rgba(0, 81, 255, 0.08); border-left-color: var(--accent); color: var(--fg-strong);
  }
  .b2b-acceso__form-banner a { color: inherit; text-decoration: underline; }

  .b2b-acceso__fieldset { border: 0; padding: 0; margin: 0; }
  .b2b-acceso__fieldset-legend {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.6rem; font-weight: 400; color: var(--fg-strong);
    margin: 0 0 1.25rem; padding: 0; letter-spacing: -0.005em;
  }
  .b2b-acceso__form-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem 1.25rem;
  }
  .b2b-acceso__field { display: flex; flex-direction: column; gap: 0.5rem; }
  .b2b-acceso__field--wide { grid-column: 1 / -1; }
  .b2b-acceso__field label { font-size: 1.4rem; color: var(--fg-muted); letter-spacing: 0.01em; }
  .b2b-acceso__req { color: var(--accent); }
  .b2b-acceso__optional { color: var(--fg-dim); font-size: 0.875em; }
  .b2b-acceso__field input, .b2b-acceso__field select {
    width: 100%; padding: 1rem 1.125rem; background: #ffffff;
    border: 1px solid var(--border); border-radius: 6px;
    color: var(--fg-strong); font-family: inherit;
    font-size: 1.6rem; line-height: 1.5;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .b2b-acceso__field input:hover, .b2b-acceso__field select:hover { border-color: rgba(0, 0, 0, 0.25); }
  .b2b-acceso__field input:focus, .b2b-acceso__field select:focus {
    outline: 2px solid var(--accent); outline-offset: 1px;
    border-color: var(--accent); background: rgba(0, 81, 255, 0.04);
  }
  .b2b-acceso__field input[readonly], .b2b-acceso__field input:disabled {
    background: rgba(0, 0, 0, 0.04); color: var(--fg-muted); cursor: not-allowed;
  }
  .b2b-acceso__field input[aria-invalid="true"], .b2b-acceso__field select[aria-invalid="true"] {
    border-color: #dc2626;
  }
  .b2b-acceso__field-error { font-size: 1.3rem; color: #991b1b; line-height: 1.4; }
  .b2b-acceso__field-note { font-size: 1.3rem; color: var(--fg-dim); line-height: 1.4; }

  .b2b-acceso__terms {
    display: flex; align-items: flex-start; gap: 0.875rem;
    padding: 1.25rem 1.5rem; background: rgba(0, 0, 0, 0.04); border-radius: 8px;
  }
  .b2b-acceso__terms input[type="checkbox"] {
    margin-top: 0.25rem; flex-shrink: 0; width: 1.6rem; height: 1.6rem; accent-color: var(--accent);
  }
  .b2b-acceso__terms label { font-size: 1.5rem; line-height: 1.55; color: var(--fg-muted); cursor: pointer; }
  .b2b-acceso__terms a { color: var(--accent); text-decoration: underline; }

  .b2b-acceso__btn--submit { align-self: flex-start; min-width: 22rem; position: relative; }
  .b2b-acceso__btn--submit:disabled { cursor: not-allowed; transform: none; }
  .b2b-acceso__btn-spinner {
    display: inline-block; width: 1.4rem; height: 1.4rem; margin-left: 0.875rem;
    border: 2px solid rgba(0, 0, 0, 0.2); border-top-color: currentColor;
    border-radius: 50%; animation: b2b-acceso-spin 0.8s linear infinite;
    vertical-align: -0.2rem;
  }
  .b2b-acceso__btn-spinner[hidden] { display: none; }
  @keyframes b2b-acceso-spin { to { transform: rotate(360deg); } }
  @media (max-width: 750px) {
    .b2b-acceso__form-block { padding: 2rem 1.25rem; }
    .b2b-acceso__btn--submit { width: 100%; min-width: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .b2b-acceso__btn, .b2b-acceso__btn-spinner { transition: none; animation: none; }
  }
</style>

<script>
  // i18n bundle inyectado antes del script defer para garantizar
  // disponibilidad de window.LEDSC4_I18N.{acceso_form,completar} en el IIFE.
  window.LEDSC4_I18N = window.LEDSC4_I18N || {};
  window.LEDSC4_I18N.locale_prefix = {{ locale_prefix | json }};
  window.LEDSC4_I18N.acceso_form = {
    err: {
      required: {{ 'ledsc4.acceso.form.err.required' | t | json }},
      email:    {{ 'ledsc4.acceso.form.err.email' | t | json }},
      nif:        {{ 'ledsc4.acceso.form.err.nif' | t | json }},
      nif_format: {{ 'ledsc4.acceso.form.err.nif_format' | t | json }},
      terms:      {{ 'ledsc4.acceso.form.err.terms' | t | json }}
    },
    submit:         {{ 'ledsc4.acceso.form.submit' | t | json }},
    submit_loading: {{ 'ledsc4.acceso.form.submit_loading' | t | json }},
    banner: {
      config_missing:           {{ 'ledsc4.acceso.form.banner.config_missing' | t | json }},
      signature_expired_html:   {{ 'ledsc4.acceso.form.banner.signature_expired_html' | t | json }},
      service_unavailable_html: {{ 'ledsc4.acceso.form.banner.service_unavailable_html' | t | json }},
      generic_fallback:         {{ 'ledsc4.acceso.form.banner.generic_fallback' | t | json }},
      network_error:            {{ 'ledsc4.acceso.form.banner.network_error' | t | json }}
    }
  };
  window.LEDSC4_I18N.completar = {
    form: {
      submit: {{ 'ledsc4.completar.form.submit' | t | json }}
    },
    banner: {
      session_error:   {{ 'ledsc4.completar.banner.session_error' | t | json }},
      invalid_payload: {{ 'ledsc4.completar.banner.invalid_payload' | t | json }}
    }
  };
</script>
<script src="{{ 'b2b-complete.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Completar registro",
  "tag": "section",
  "class": "section-b2b-completar",
  "settings": [
    {
      "type": "header",
      "content": "Apariencia"
    },
    {
      "type": "checkbox",
      "id": "show_logo_header",
      "label": "Mostrar logo en cabecera",
      "default": false
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding superior",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding inferior",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Completar registro"
    }
  ]
}
{% endschema %}
