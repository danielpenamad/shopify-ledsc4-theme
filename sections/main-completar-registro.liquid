{% comment %}
  Página /pages/completar-registro.

  Carril para clientes que se registraron por New Customer Accounts (alta
  nativa, sin formulario B2B) y se quedaron en el limbo: customer existe,
  pero sin metafields b2b.* ni tag de estado. El gate B2B en
  layout/theme.liquid (Fase 1) los redirige aquí desde URLs comerciales.

  El form hace customerUpdate sobre el customer YA logueado vía la edge
  function `complete-b2b-registration` (Fase 3, ya desplegada). NO usa
  customerCreate: el customer ya existe y daría EMAIL_ALREADY_EXISTS.

  Tres ramas de render:
    - customer == nil           → bloque "inicia sesión" + CTA al login.
    - customer.tags contains
      'aprobado' o 'rechazado'  → "tu cuenta ya está gestionada" + CTA inicio.
    - resto                     → formulario completar (incluye 'pendiente'
                                  como caso de reintento).

  Auth del form: HMAC-SHA256 de `<timestamp>:<nonce>:<gid>` con
  settings.register_b2b_hmac_secret (MISMO secret que register-b2b-customer;
  el gid en la firma evita reuso entre carriles). TTL 1 hora.

  Reutiliza la nomenclatura BEM `b2b-acceso__*` para herencia visual
  con /pages/acceso-profesional. El `<style>` se duplica intacto (las dos
  páginas son sibling templates; no se cargan a la vez).
{% endcomment %}

{%- liquid
  assign locale_prefix = routes.root_url
  if locale_prefix == '/'
    assign locale_prefix = ''
  endif
-%}
{%- assign login_return_to = locale_prefix | append: '/pages/completar-registro' | url_encode -%}

<section
  class="b2b-acceso"
  aria-labelledby="b2b-completar-heading"
  style="--b2b-acceso-pad-top: {{ section.settings.padding_top | default: 64 }}px; --b2b-acceso-pad-bottom: {{ section.settings.padding_bottom | default: 80 }}px;"
>

  {%- if section.settings.show_logo_header -%}
    <header class="b2b-acceso__brand">
      {%- if shop.brand.logo != blank -%}
        <img src="{{ shop.brand.logo | image_url: width: 360 }}" alt="{{ shop.name | escape }}" width="160" height="auto" loading="eager">
      {%- else -%}
        <span class="b2b-acceso__brand-wordmark">LedsC4 <em>Outlet</em></span>
      {%- endif -%}
    </header>
  {%- endif -%}

  <div class="b2b-acceso__hero">
    <p class="b2b-acceso__eyebrow">{{ 'ledsc4.completar.hero.eyebrow' | t }}</p>
    <h1 id="b2b-completar-heading" class="b2b-acceso__heading">
      {{ 'ledsc4.completar.hero.heading_html' | t }}
    </h1>
    <p class="b2b-acceso__lead">
      {{ 'ledsc4.completar.hero.lead' | t }}
    </p>
  </div>

  {%- if customer == nil -%}

    {%- comment -%} Rama A: anónimo. {%- endcomment -%}
    <div class="b2b-acceso__ctas-block">
      <h2 class="b2b-acceso__h2">{{ 'ledsc4.completar.msg_anonimo.heading' | t }}</h2>
      <p class="b2b-acceso__ctas-lead">{{ 'ledsc4.completar.msg_anonimo.lead' | t }}</p>
      <div class="b2b-acceso__ctas">
        <a href="/customer_authentication/login?return_to={{ login_return_to }}&locale={{ request.locale.iso_code }}" class="b2b-acceso__btn b2b-acceso__btn--primary">
          {{ 'ledsc4.completar.msg_anonimo.cta' | t }}
        </a>
      </div>
    </div>

  {%- elsif customer.tags contains 'aprobado' or customer.tags contains 'rechazado' -%}

    {%- comment -%} Rama B: estado terminal — no hace falta completar nada. {%- endcomment -%}
    <div class="b2b-acceso__ctas-block">
      <h2 class="b2b-acceso__h2">{{ 'ledsc4.completar.msg_ya_gestionada.heading' | t }}</h2>
      <p class="b2b-acceso__ctas-lead">{{ 'ledsc4.completar.msg_ya_gestionada.lead' | t }}</p>
      <div class="b2b-acceso__ctas">
        <a href="{{ locale_prefix }}/" class="b2b-acceso__btn b2b-acceso__btn--primary">
          {{ 'ledsc4.completar.msg_ya_gestionada.cta' | t }}
        </a>
      </div>
    </div>

  {%- else -%}

    {%- comment -%}
      Rama C: customer logueado sin estado terminal. Form completar.
      HMAC payload incluye el gid del customer para evitar reuso entre
      carriles register / complete.
    {%- endcomment -%}
    {%- assign complete_customer_gid = 'gid://shopify/Customer/' | append: customer.id -%}
    {%- assign complete_now_ts = 'now' | date: '%s' -%}
    {%- assign complete_nonce_seed = complete_now_ts | append: ':' | append: section.id | append: ':' | append: customer.id -%}
    {%- assign complete_nonce = complete_nonce_seed | sha256 | slice: 0, 24 -%}
    {%- assign complete_hmac_payload = complete_now_ts | append: ':' | append: complete_nonce | append: ':' | append: complete_customer_gid -%}
    {%- assign complete_hmac_sig = complete_hmac_payload | hmac_sha256: settings.register_b2b_hmac_secret -%}

    <section class="b2b-acceso__form-block" aria-labelledby="b2b-completar-form-heading">
      <h2 id="b2b-completar-form-heading" class="b2b-acceso__h2">{{ 'ledsc4.completar.form.heading' | t }}</h2>

      <form
        id="b2b-completar-form"
        class="b2b-acceso__form"
        data-endpoint="{{ settings.complete_b2b_endpoint }}"
        novalidate
        onsubmit="return false;"
      >
        <input type="hidden" name="timestamp" value="{{ complete_now_ts }}">
        <input type="hidden" name="nonce" value="{{ complete_nonce }}">
        <input type="hidden" name="signature" value="{{ complete_hmac_sig }}">
        <input type="hidden" name="customerId" value="{{ complete_customer_gid }}">
        <input type="hidden" name="sector" value="otro">

        <div id="b2b-completar-banner" class="b2b-acceso__form-banner" hidden role="alert"></div>

        <fieldset class="b2b-acceso__fieldset">
          <legend class="b2b-acceso__fieldset-legend">{{ 'ledsc4.acceso.form.legend_personales' | t }}</legend>
          <div class="b2b-acceso__form-grid">
            <div class="b2b-acceso__field">
              <label for="comp-nombre">{{ 'ledsc4.acceso.form.label_nombre' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
              <input type="text" name="nombre" id="comp-nombre" autocomplete="given-name" required maxlength="100" value="{{ customer.first_name | escape }}">
              <span class="b2b-acceso__field-error" data-field="nombre" hidden></span>
            </div>
            <div class="b2b-acceso__field">
              <label for="comp-apellidos">{{ 'ledsc4.acceso.form.label_apellidos' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
              <input type="text" name="apellidos" id="comp-apellidos" autocomplete="family-name" required maxlength="100" value="{{ customer.last_name | escape }}">
              <span class="b2b-acceso__field-error" data-field="apellidos" hidden></span>
            </div>
            <div class="b2b-acceso__field">
              <label for="comp-email">{{ 'ledsc4.completar.form.email_label' | t }}</label>
              <input type="email" id="comp-email" value="{{ customer.email | escape }}" readonly disabled aria-readonly="true">
              <span class="b2b-acceso__field-note">{{ 'ledsc4.completar.form.email_note' | t }}</span>
            </div>
            <div class="b2b-acceso__field">
              <label for="comp-telefono">{{ 'ledsc4.acceso.form.label_telefono' | t }}</label>
              <input type="tel" name="telefono" id="comp-telefono" autocomplete="tel" maxlength="30" inputmode="tel" value="{{ customer.phone | escape }}">
              <span class="b2b-acceso__field-error" data-field="telefono" hidden></span>
            </div>
          </div>
        </fieldset>

        <fieldset class="b2b-acceso__fieldset">
          <legend class="b2b-acceso__fieldset-legend">{{ 'ledsc4.acceso.form.legend_empresa' | t }}</legend>
          <div class="b2b-acceso__form-grid">
            <div class="b2b-acceso__field b2b-acceso__field--wide">
              <label for="comp-empresa">{{ 'ledsc4.acceso.form.label_razon_social' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
              <input type="text" name="empresa" id="comp-empresa" autocomplete="organization" required maxlength="200">
              <span class="b2b-acceso__field-error" data-field="empresa" hidden></span>
            </div>
            <div class="b2b-acceso__field">
              <label for="comp-nif">{{ 'ledsc4.acceso.form.label_nif' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
              <input type="text" name="nif" id="comp-nif" required maxlength="20" autocapitalize="characters" spellcheck="false">
              <span class="b2b-acceso__field-error" data-field="nif" hidden></span>
            </div>
            <div class="b2b-acceso__field">
              <label for="comp-pais">{{ 'ledsc4.acceso.form.label_pais' | t }} <span class="b2b-acceso__req" aria-hidden="true">*</span></label>
              {%- comment -%}
                Lista paritaria con /pages/acceso-profesional (89 países, ES
                primero, resto alfabético por nombre en español, GB→"UK").
              {%- endcomment -%}
              <select name="pais" id="comp-pais" required>
                <option value="" disabled selected>{{ 'ledsc4.common.form.option_select' | t }}</option>
                <option value="ES">{{ 'ledsc4.common.country.es' | t }}</option>
                <option value="AL">{{ 'ledsc4.common.country.al' | t }}</option>
                <option value="DE">{{ 'ledsc4.common.country.de' | t }}</option>
                <option value="AD">{{ 'ledsc4.common.country.ad' | t }}</option>
