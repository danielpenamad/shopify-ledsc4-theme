{% comment %}
  Página /pages/cuenta-rechazada
  Mostrada a customers con tag 'rechazado' cuando Locksmith los redirige.
  Muestra el motivo (si se rellenó) y el email de contacto.
{% endcomment %}

<section class="b2b-status" aria-labelledby="b2b-status-heading">
  <div class="b2b-status__inner">
    <span class="b2b-status__badge b2b-status__badge--rejected">No activada</span>
    <h1 id="b2b-status-heading" class="b2b-status__heading">
      Tu cuenta no ha podido activarse
    </h1>

    <p class="b2b-status__lead">
      {{- page.metafields.b2b.cuenta_rechazada_mensaje | default: section.settings.default_message -}}
    </p>

    {%- if customer and customer.metafields.b2b.motivo_rechazo != blank -%}
      <div class="b2b-status__datos b2b-status__datos--motivo">
        <h2 class="b2b-status__datos-heading">Motivo</h2>
        <p class="b2b-status__motivo">
          {{ customer.metafields.b2b.motivo_rechazo }}
        </p>
      </div>
    {%- endif -%}

    <p class="b2b-status__correct">
      Si crees que es un error o quieres ampliar información, escríbenos a
      <a href="mailto:{{ shop.metafields.b2b.email_backoffice | default: 'backoffice@ledsc4.com' }}">
        {{ shop.metafields.b2b.email_backoffice | default: 'backoffice@ledsc4.com' }}
      </a>.
    </p>

    <div class="b2b-status__ctas">
      <a href="/account/logout" class="b2b-status__btn b2b-status__btn--secondary">
        Cerrar sesión
      </a>
    </div>
  </div>
</section>

<style>
  .b2b-status {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: rgba(15, 18, 23, 0.95);
  }

  .b2b-status__inner {
    max-width: 560px;
    width: 100%;
    text-align: center;
  }

  .b2b-status__badge {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .b2b-status__badge--rejected {
    background: rgba(210, 60, 40, 0.1);
    color: rgb(150, 35, 20);
  }

  .b2b-status__heading {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 1rem;
    letter-spacing: -0.015em;
  }

  .b2b-status__lead {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: rgba(15, 18, 23, 0.7);
    margin: 0 auto 2rem;
    max-width: 480px;
  }

  .b2b-status__datos {
    background: rgba(15, 18, 23, 0.03);
    border-radius: 0.75rem;
    padding: 1.5rem 2rem;
    margin: 0 0 1.75rem;
    text-align: left;
  }

  .b2b-status__datos--motivo {
    border-left: 3px solid rgba(210, 60, 40, 0.5);
  }

  .b2b-status__datos-heading {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: rgba(15, 18, 23, 0.55);
  }

  .b2b-status__motivo {
    margin: 0;
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(15, 18, 23, 0.85);
  }

  .b2b-status__correct {
    font-size: 0.9375rem;
    color: rgba(15, 18, 23, 0.7);
    margin: 0 0 2rem;
    line-height: 1.55;
  }

  .b2b-status__correct a {
    color: rgba(15, 18, 23, 0.9);
    text-decoration: underline;
  }

  .b2b-status__ctas {
    display: flex;
    justify-content: center;
  }

  .b2b-status__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .b2b-status__btn--secondary {
    background: transparent;
    color: rgba(15, 18, 23, 0.7);
    border: 1px solid rgba(15, 18, 23, 0.15);
  }

  .b2b-status__btn--secondary:hover {
    background: rgba(15, 18, 23, 0.04);
  }
</style>

{% schema %}
{
  "name": "B2B Cuenta Rechazada",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "default_message",
      "label": "Mensaje por defecto (fallback si el metafield page.b2b.cuenta_rechazada_mensaje está vacío)",
      "default": "Nuestro equipo ha revisado tu solicitud y no ha sido posible activar la cuenta en esta ocasión."
    }
  ],
  "presets": [
    {
      "name": "B2B Cuenta Rechazada"
    }
  ]
}
{% endschema %}
