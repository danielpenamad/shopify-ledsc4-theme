<!--
  Email 5 — Cuenta rechazada.
  Disparador: W3 (Send marketing mail).
  El motivo se muestra solo si está poblado.
  Asunto: Estado de tu solicitud B2B
-->

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafaf7;margin:0;padding:0;">
  <tr>
    <td align="center" style="padding:40px 16px;">
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;background:#ffffff;border-radius:8px;overflow:hidden;">

        <tr>
          <td align="center" style="padding:36px 40px 24px 40px;border-bottom:1px solid #eeeeee;">
            {% if shop.brand.logo %}
              <img src="{{ shop.brand.logo.src | image_url: width: 400 }}" alt="{{ shop.name }}" width="160" style="display:block;margin:0 auto;border:0;">
            {% else %}
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:22px;letter-spacing:0.08em;color:#1a1f27;">LEDS C4 · Outlet</div>
            {% endif %}
          </td>
        </tr>

        <tr>
          <td style="padding:32px 40px 8px 40px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1a1f27;">
            <h1 style="font-size:22px;font-weight:600;margin:0 0 16px 0;line-height:1.3;letter-spacing:-0.01em;">Estado de tu solicitud</h1>
            <p style="font-size:16px;line-height:1.55;margin:0 0 16px 0;">Hola {{ customer.first_name }},</p>
            <p style="font-size:16px;line-height:1.55;margin:0 0 16px 0;">Tu solicitud de alta en el portal B2B de <strong>LedsC4 Outlet</strong> no ha podido aprobarse en esta ocasión.</p>
          </td>
        </tr>

        {% if customer.metafields.b2b.motivo_rechazo != blank %}
        <tr>
          <td style="padding:0 40px 24px 40px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1a1f27;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fdf5f3;border-left:3px solid #c83e26;border-radius:6px;">
              <tr>
                <td style="padding:14px 18px;">
                  <p style="font-size:13px;color:#c83e26;margin:0 0 6px 0;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;">Motivo</p>
                  <p style="font-size:15px;margin:0;line-height:1.55;">{{ customer.metafields.b2b.motivo_rechazo }}</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        {% endif %}

        <tr>
          <td style="padding:{% if customer.metafields.b2b.motivo_rechazo != blank %}0{% else %}8px{% endif %} 40px 28px 40px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#666;font-size:15px;line-height:1.55;">
            <p style="margin:0;">Si crees que es un error o quieres ampliar información, escríbenos a <a href="mailto:{{ shop.metafields.b2b.email_backoffice | default: 'backoffice@ledsc4.com' }}" style="color:#1a1f27;">{{ shop.metafields.b2b.email_backoffice | default: 'backoffice@ledsc4.com' }}</a>.</p>
          </td>
        </tr>

        <tr>
          <td style="padding:24px 40px;background:#fafaf7;border-top:1px solid #eeeeee;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#888;font-size:11px;text-align:center;line-height:1.55;">
            <p style="margin:0 0 6px 0;"><strong style="color:#666;">LEDS C4, SA</strong> · CIF A59410910</p>
            <p style="margin:0 0 10px 0;">Carretera de Rubí 88, 2ª planta, Sant Cugat del Vallés</p>
            <p style="margin:0;"><a href="{{ unsubscribe_link }}" style="color:#888;text-decoration:underline;">Darte de baja</a></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

{{ open_tracking_block }}
