<!--
  Email 7b — Notificacion al backoffice de nueva solicitud B2B.
  Disparador: Flow W5, step Send internal email (inline HTML).
  NO es marketing mail: NO incluye {{ unsubscribe_link }}. Cuerpo va
  pegado tal cual en el campo "Email body" del Send internal email step.
  To: hardcoded literal — ver docs/hardcoded-emails.md.

  IMPORTANTE: Flow Liquid sandbox NO accede a metafields dotted ni a
  draftOrder.note. Antes de este email, el workflow ejecuta un Run code
  que aplana los campos problematicos en runCode.xxx. Ver
  email-templates/WALKTHROUGH-W5.md seccion 4.

  Asunto (Subject del Send internal email, NO parte de este body):
    Nueva solicitud B2B · {{ runCode.empresa }} · {{ draftOrder.name }}
-->

<div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1a1f27;max-width:720px;margin:0 auto;padding:24px;">

  <h2 style="font-size:18px;font-weight:600;margin:0 0 16px 0;border-bottom:2px solid #1a1f27;padding-bottom:8px;">Nueva solicitud B2B · {{ draftOrder.name }}</h2>

  <!-- CLIENTE -->
  <h3 style="font-size:13px;text-transform:uppercase;color:#666;letter-spacing:0.05em;margin:20px 0 8px 0;">Cliente</h3>
  <table cellpadding="4" style="font-size:14px;border-collapse:collapse;">
    <tr><td style="color:#666;padding-right:16px;">Empresa:</td><td><strong>{{ runCode.empresa }}</strong></td></tr>
    <tr><td style="color:#666;padding-right:16px;">NIF / CIF:</td><td>{{ runCode.nif }}</td></tr>
    <tr><td style="color:#666;padding-right:16px;">Nombre:</td><td>{{ draftOrder.customer.displayName }}</td></tr>
    <tr><td style="color:#666;padding-right:16px;">Email:</td><td><a href="mailto:{{ runCode.customerEmail }}" style="color:#1a1f27;">{{ runCode.customerEmail }}</a></td></tr>
    {% if runCode.customerPhone != blank %}<tr><td style="color:#666;padding-right:16px;">Teléfono:</td><td>{{ runCode.customerPhone }}</td></tr>{% endif %}
    <tr><td style="color:#666;padding-right:16px;">Sector:</td><td>{{ runCode.sector }}</td></tr>
  </table>

  <!-- SOLICITUD -->
  <h3 style="font-size:13px;text-transform:uppercase;color:#666;letter-spacing:0.05em;margin:24px 0 8px 0;">Solicitud</h3>
  <table cellpadding="4" style="font-size:14px;border-collapse:collapse;">
    <tr><td style="color:#666;padding-right:16px;">Referencia:</td><td><strong>{{ draftOrder.name }}</strong></td></tr>
    <tr><td style="color:#666;padding-right:16px;">Fecha:</td><td>{{ draftOrder.createdAt | date: '%d/%m/%Y %H:%M' }}</td></tr>
    <tr><td style="color:#666;padding-right:16px;">Importe estimado:</td><td><strong>{{ draftOrder.totalPrice }}</strong> <span style="color:#888;">(sin IVA ni portes)</span></td></tr>
    <tr><td style="color:#666;padding-right:16px;">CBM total:</td><td><strong>{{ runCode.cbmTotal }} m³</strong></td></tr>
    <tr><td style="color:#666;padding-right:16px;">Moneda mostrada al cliente:</td><td>
      {% if runCode.monedaMostrada == blank %}<strong>no registrada</strong> <span style="color:#888;">(solicitud previa a PR-CURRENCY-B)</span>{% elsif runCode.monedaMostrada == 'EUR' %}<strong>EUR (€)</strong>{% else %}<strong>{{ runCode.monedaMostrada }} ({{ runCode.simboloMoneda }})</strong> <span style="color:#888;">— referencia visual, facturación en EUR</span>{% endif %}
    </td></tr>
  </table>

  <!-- LINEAS -->
  <h3 style="font-size:13px;text-transform:uppercase;color:#666;letter-spacing:0.05em;margin:24px 0 8px 0;">Líneas solicitadas</h3>
  <table cellpadding="6" cellspacing="0" style="font-size:13px;border-collapse:collapse;width:100%;border:1px solid #e0e0e0;">
    <thead>
      <tr style="background:#fafaf7;">
        <th align="left" style="border-bottom:1px solid #e0e0e0;">SKU</th>
        <th align="left" style="border-bottom:1px solid #e0e0e0;">Producto</th>
        <th align="right" style="border-bottom:1px solid #e0e0e0;">Uds.</th>
      </tr>
    </thead>
    <tbody>
      {% for line in draftOrder.lineItems %}
        <tr style="border-bottom:1px solid #f0f0f0;">
          <td style="color:#999;">{{ line.sku }}</td>
          <td>{{ line.title }}{% if line.variantTitle != blank %} · <span style="color:#888;">{{ line.variantTitle }}</span>{% endif %}</td>
          <td align="right">{{ line.quantity }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
  <p style="font-size:12px;color:#888;margin:4px 0 0 0;">Precios completos disponibles en el draft order (ver CTA abajo).</p>

  <!-- COMENTARIO -->
  {% if runCode.note != blank %}
    <h3 style="font-size:13px;text-transform:uppercase;color:#666;letter-spacing:0.05em;margin:24px 0 8px 0;">Comentario del cliente</h3>
    <div style="background:#fff8e1;border-left:3px solid #d4a84a;padding:12px 16px;font-size:14px;line-height:1.55;color:#555;font-style:italic;">{{ runCode.note }}</div>
  {% endif %}

  <!-- CTA -->
  <div style="margin-top:32px;text-align:center;">
    <a href="https://admin.shopify.com/store/ledsc4-b2b-outlet/draft_orders/{{ draftOrder.legacyResourceId }}" style="display:inline-block;background:#1a1f27;color:#ffffff;padding:12px 28px;border-radius:6px;text-decoration:none;font-size:15px;font-weight:500;">Abrir en admin</a>
  </div>

  <p style="font-size:11px;color:#888;margin-top:24px;text-align:center;">Notificacion interna · no responder a este correo.</p>
</div>
